    756  f384							;-------------------------------------------------------------
    757  f384							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
    758  f384							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
    759  f384							;   (After examples/6-digit-score.asm.)
    760  f384							;-------------------------------------------------------------
    761  f384				   GetDigitPtrs
    762  f384		       a5 c1		      lda	gameState
    763  f386		       d0 26		      bne	.goText
    764  f388							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
    765  f388		       a9 50		      lda	#<BlankGlyph
    766  f38a		       85 c8		      sta	Digit0+0
    767  f38c		       85 ca		      sta	Digit0+2
    768  f38e		       a2 04		      ldx	#4
    769  f390		       a0 01		      ldy	#1
    770  f392				   .gdpLoop
    771  f392		       b9 c2 00 	      lda	scoreBCD,y
    772  f395		       29 f0		      and	#$f0	; high nibble * 16
    773  f397		       4a		      lsr		; -> * 8
    774  f398		       95 c8		      sta	Digit0,x
    775  f39a		       e8		      inx
    776  f39b		       e8		      inx
    777  f39c		       b9 c2 00 	      lda	scoreBCD,y
    778  f39f		       29 0f		      and	#$0f	; low nibble
    779  f3a1		       0a		      asl
    780  f3a2		       0a		      asl
    781  f3a3		       0a		      asl		; * 8
    782  f3a4		       95 c8		      sta	Digit0,x
    783  f3a6		       e8		      inx
    784  f3a7		       e8		      inx
    785  f3a8		       88		      dey
    786  f3a9		       10 e7		      bpl	.gdpLoop
    787  f3ab		       4c f5 f3 	      jmp	.setHi
    788  f3ae				   .goText
    789  f3ae							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
    790  f3ae		       a5 c7		      lda	goCnt
    791  f3b0		       c9 78		      cmp	#120
    792  f3b2		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
    793  f3b4							; "GAMEOVER" packed across the 6 glyph slots
    794  f3b4		       a9 58		      lda	#<GameOverGlyphs
    795  f3b6		       85 c8		      sta	Digit0+0
    796  f3b8		       18		      clc
    797  f3b9		       69 08		      adc	#8
    798  f3bb		       85 ca		      sta	Digit0+2
    799  f3bd		       69 08		      adc	#8
    800  f3bf		       85 cc		      sta	Digit0+4
    801  f3c1		       69 08		      adc	#8
    802  f3c3		       85 ce		      sta	Digit0+6
    803  f3c5		       69 08		      adc	#8
    804  f3c7		       85 d0		      sta	Digit0+8
    805  f3c9		       69 08		      adc	#8
    806  f3cb		       85 d2		      sta	Digit0+10
    807  f3cd		       4c f5 f3 	      jmp	.setHi
    808  f3d0				   .goHi
    809  f3d0							; "HI" + the 4-digit high score
    810  f3d0		       a9 88		      lda	#<LetterH
    811  f3d2		       85 c8		      sta	Digit0+0
    812  f3d4		       a9 90		      lda	#<LetterI
    813  f3d6		       85 ca		      sta	Digit0+2
    814  f3d8		       a2 04		      ldx	#4
    815  f3da		       a0 01		      ldy	#1
    816  f3dc				   .goHiLoop
    817  f3dc		       b9 c5 00 	      lda	hiScore,y
    818  f3df		       29 f0		      and	#$f0
    819  f3e1		       4a		      lsr
    820  f3e2		       95 c8		      sta	Digit0,x
    821  f3e4		       e8		      inx
    822  f3e5		       e8		      inx
    823  f3e6		       b9 c5 00 	      lda	hiScore,y
    824  f3e9		       29 0f		      and	#$0f
    825  f3eb		       0a		      asl
    826  f3ec		       0a		      asl
    827  f3ed		       0a		      asl
    828  f3ee		       95 c8		      sta	Digit0,x
    829  f3f0		       e8		      inx
    830  f3f1		       e8		      inx
    831  f3f2		       88		      dey
    832  f3f3		       10 e7		      bpl	.goHiLoop
