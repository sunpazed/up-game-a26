    766  f384							;-------------------------------------------------------------
    767  f384							; CheckCollision - player vs the entity on the player's floor.
    768  f384							;   cone  -> +1 to the BCD score, entity consumed.
    769  f384							;   skull -> game over (freeze + red background).
    770  f384							;-------------------------------------------------------------
    771  f384				   CheckCollision
    772  f384		       a5 07		      lda	CXPPMM
    773  f386		       10 50		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    774  f388							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    775  f388							; entity on playerFloor. Act on its type.
    776  f388		       a6 80		      ldx	playerFloor
    777  f38a		       b5 9d		      lda	entType,x
    778  f38c		       f0 4a		      beq	.ccDone	; guard: no entity here
    779  f38e		       c9 02		      cmp	#ENT_SKULL
    780  f390		       f0 28		      beq	.ccSkull
    781  f392							; cone collected: +1 (BCD). GetDigitPtrs shows scoreBCD+2 as the
    782  f392							; leftmost (most-significant) digits, so the +1 must land on the
    783  f392							; least-significant byte scoreBCD+0 and carry up toward +2.
    784  f392		       f8		      sed
    785  f393		       a5 c3		      lda	scoreBCD+0
    786  f395		       18		      clc
    787  f396		       69 01		      adc	#1
    788  f398		       85 c3		      sta	scoreBCD+0
    789  f39a		       a5 c4		      lda	scoreBCD+1
    790  f39c		       69 00		      adc	#0
    791  f39e		       85 c4		      sta	scoreBCD+1
    792  f3a0		       a5 c5		      lda	scoreBCD+2
    793  f3a2		       69 00		      adc	#0
    794  f3a4		       85 c5		      sta	scoreBCD+2
    795  f3a6		       d8		      cld
    796  f3a7		       a9 00		      lda	#0
    797  f3a9		       95 9d		      sta	entType,x	; cone consumed
    798  f3ab		       20 79 f3 	      jsr	SetRespawnDelay	; wait before a new entity enters this floor
    799  f3ae							; ramp the scroll speed (sub-pixel speed-up with score)
    800  f3ae		       a5 af		      lda	scrollSpeed
    801  f3b0		       c9 80		      cmp	#SPEED_MAX
    802  f3b2		       b0 24		      bcs	.ccDone	; already at max
    803  f3b4		       18		      clc
    804  f3b5		       69 01		      adc	#SPEED_INC
    805  f3b7		       85 af		      sta	scrollSpeed
    806  f3b9		       60		      rts
    807  f3ba				   .ccSkull
    808  f3ba		       a9 01		      lda	#1
    809  f3bc		       85 c2		      sta	gameState
    810  f3be		       a9 42		      lda	#COL_GAMEOVER
    811  f3c0		       85 09		      sta	COLUBK	; red tint; NewGame restores COL_BG on restart
    812  f3c2							; high score = max(hiScore, score) over the low 4 digits
    813  f3c2		       a5 c4		      lda	scoreBCD+1
    814  f3c4		       c5 c7		      cmp	hiScore+1
    815  f3c6		       90 10		      bcc	.ccDone	; score's high pair < hiScore's
    816  f3c8		       d0 06		      bne	.ccNewHi	; score's high pair > hiScore's
    817  f3ca		       a5 c3		      lda	scoreBCD+0
    818  f3cc		       c5 c6		      cmp	hiScore+0
    819  f3ce		       90 08		      bcc	.ccDone	; equal high pair, low pair lower
    820  f3d0				   .ccNewHi
    821  f3d0		       a5 c3		      lda	scoreBCD+0
    822  f3d2		       85 c6		      sta	hiScore+0
    823  f3d4		       a5 c4		      lda	scoreBCD+1
    824  f3d6		       85 c7		      sta	hiScore+1
    825  f3d8				   .ccDone
    826  f3d8		       60		      rts
