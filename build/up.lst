    904  f44a							;-------------------------------------------------------------
    905  f44a							; Missile-0 cycle-74 strobe table (must stay within one page).
    906  f44a							;   Each entry strobes RESM0; the $1C (NOP abs) swallows the next
    907  f44a							;   entry's `sta RESM0`, so only the jumped-to strobe executes, then
    908  f44a							;   execution falls through to `sta HMOVE` at cycle ~74.
    909  f44a							;-------------------------------------------------------------
    910  f500					      org	$f500
    911  f500				   PosTblM0
    912  f500				   pM0_3
    913  f500		       85 12		      sta	RESM0
    914  f502		       1c		      .byte.b	$1C
    915  f503				   pM0_15
    916  f503		       85 12		      sta	RESM0
    917  f505		       1c		      .byte.b	$1C
    918  f506				   pM0_30
    919  f506		       85 12		      sta	RESM0
    920  f508		       1c		      .byte.b	$1C
    921  f509				   pM0_45
    922  f509		       85 12		      sta	RESM0
    923  f50b		       1c		      .byte.b	$1C
    924  f50c				   pM0_60
    925  f50c		       85 12		      sta	RESM0
    926  f50e		       1c		      .byte.b	$1C
    927  f50f				   pM0_75
    928  f50f		       85 12		      sta	RESM0
    929  f511		       1c		      .byte.b	$1C
    930  f512				   pM0_90
    931  f512		       85 12		      sta	RESM0
    932  f514		       1c		      .byte.b	$1C
    933  f515				   pM0_105
    934  f515		       85 12		      sta	RESM0
    935  f517		       1c		      .byte.b	$1C
    936  f518				   pM0_120
    937  f518		       85 12		      sta	RESM0
    938  f51a		       1c		      .byte.b	$1C
    939  f51b				   pM0_135
    940  f51b		       85 12		      sta	RESM0
    941  f51d		       1c		      .byte.b	$1C
    942  f51e				   pM0_150
    943  f51e		       85 12		      sta	RESM0
    944  f520		       85 2a		      sta	HMOVE
    945  f522		       85 02		      sta	WSYNC	; re-align: the positioning line ends here so the
    946  f524		       60		      rts		; band keeps an exact, identical scanline budget
    947  f525
    948  f525				   JumpTabM0
    949  f525		       00 03 06 09*	      .byte.b	<pM0_3, <pM0_15, <pM0_30, <pM0_45, <pM0_60, <pM0_75
    950  f52b		       12 15 18 1b*	      .byte.b	<pM0_90, <pM0_105, <pM0_120, <pM0_135, <pM0_150
    951  f530
