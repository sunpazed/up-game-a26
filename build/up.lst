    606  f2b1		       30 0c		      bmi	.store	; bit7 set => not pressed
    607  f2b3		       a2 01		      ldx	#1	; pressed
    608  f2b5		       a5 82		      lda	btnPrev
    609  f2b7		       d0 06		      bne	.store	; held => no new press
    610  f2b9		       a5 80		      lda	playerFloor
    611  f2bb		       f0 02		      beq	.store	; already at top tier
    612  f2bd		       c6 80		      dec	playerFloor	; jump up one tier
    613  f2bf				   .store
    614  f2bf		       86 82		      stx	btnPrev
    615  f2c1		       60		      rts
    616  f2c2
    617  f2c2							;-------------------------------------------------------------
    618  f2c2							; AnimatePlayer - tick the run-cycle frame. Swaps frame every animTimer
    619  f2c2							;   frames; the interval shortens with scroll speed so the player's legs
    620  f2c2							;   move faster as the world speeds up.
    621  f2c2							;   interval = ANIM_BASE - (scrollSpeed >> 3)
    622  f2c2							;-------------------------------------------------------------
    623  f2c2				   AnimatePlayer
    624  f2c2		       c6 ca		      dec	animTimer
    625  f2c4		       d0 14		      bne	.apDone
    626  f2c6		       a5 c9		      lda	animFrame
    627  f2c8		       49 01		      eor	#1
    628  f2ca		       85 c9		      sta	animFrame	; toggle 0 <-> 1
    629  f2cc		       a5 af		      lda	scrollSpeed
    630  f2ce		       4a		      lsr
    631  f2cf		       4a		      lsr
    632  f2d0		       4a		      lsr		; scrollSpeed >> 3
    633  f2d1		       85 ca		      sta	animTimer	; (temp)
    634  f2d3		       a9 16		      lda	#ANIM_BASE
    635  f2d5		       38		      sec
    636  f2d6		       e5 ca		      sbc	animTimer
    637  f2d8		       85 ca		      sta	animTimer	; reload shortened interval
    638  f2da				   .apDone
    639  f2da		       60		      rts
