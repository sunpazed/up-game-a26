    111  f01b
    112  f01b							; 36 scanlines of VBLANK. The VERTICAL_SYNC macro consumes 4 WSYNCs
    113  f01b							; total (3 VSYNC-on lines plus the line that turns VSYNC off), so this
    114  f01b							; keeps the full frame at 262 NTSC scanlines: 4 + 36 + 192 + 30.
      0  f01b					      SKIP_SCANLINES	36
      1  f01b				   .LINES     SET	36
      2  f01b		       a2 24		      ldx	#.LINES
      3  f01d		       85 02	   .vblank    sta	WSYNC
      4  f01f		       ca		      dex
      5  f020		       d0 fb		      bne	.vblank
    116  f022
    117  f022		       a9 00		      lda	#0
    118  f024		       85 01		      sta	VBLANK
    119  f026
    120  f026							; 192 visible scanlines.
    121  f026		       20 13 f2 	      jsr	DrawKernel
    122  f029
    123  f029							; Overscan with timed housekeeping.
    124  f029		       a9 02		      lda	#2
    125  f02b		       85 01		      sta	VBLANK
    126  f02d							; Debug baseline: keep overscan purely scanline-budgeted. Gameplay update
    127  f02d							; routines run for variable CPU time, so leave them disabled until the kernel
    128  f02d							; is stable and then reintroduce them inside a timer-budgeted block.
    129  f02d							; PositionObjects calls SetHorizPos five times. SetHorizPos burns two WSYNCs
    130  f02d							; per object, so this consumes 10 overscan scanlines.
    131  f02d		       20 ef f1 	      jsr	PositionObjects
    132  f030							; Complete the 30-line overscan budget: 10 positioning + 20 idle.
      0  f030					      SKIP_SCANLINES	20
      1  f030				   .LINES     SET	20
      2  f030		       a2 14		      ldx	#.LINES
      3  f032		       85 02	   .vblank    sta	WSYNC
      4  f034		       ca		      dex
      5  f035		       d0 fb		      bne	.vblank
