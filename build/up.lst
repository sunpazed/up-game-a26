    822  f3b9		       a5 07		      lda	CXPPMM
    823  f3bb		       10 60		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    824  f3bd							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    825  f3bd							; entity on playerFloor. Act on its type.
