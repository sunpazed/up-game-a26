    745  f331							; --- entities: advance position / slide / respawn wait, each by scrollStep ---
    746  f331		       a2 05		      ldx	#5
    747  f333				   .entLoop
    748  f333		       b5 9d		      lda	entType,x
    749  f335		       f0 45		      beq	.entWaiting	; hidden -> count down the respawn delay
    750  f337		       b5 cd		      lda	entSlide,x
    751  f339		       f0 28		      beq	.entScroll	; 0 -> normal scroll
    752  f33b		       30 13		      bmi	.entSlideIn	; $80|N -> sliding IN from the right edge
    753  f33d							; 1..7 -> sliding OUT the left edge: grow the shift, hide once fully off
    754  f33d		       18		      clc
    755  f33e		       65 b1		      adc	scrollStep
    756  f340		       c9 08		      cmp	#8
    757  f342		       90 1a		      bcc	.entSlideStore	; 1..7 still partly on-screen
    758  f344		       a9 00		      lda	#0
    759  f346		       95 9d		      sta	entType,x	; fully off the left edge -> hide + arm respawn
    760  f348		       95 cd		      sta	entSlide,x
    761  f34a		       20 c9 f3 	      jsr	SetRespawnDelay
    762  f34d		       4c aa f3 	      jmp	.entNext
    763  f350				   .entSlideIn
    764  f350		       38		      sec
    765  f351		       e5 b1		      sbc	scrollStep	; $80|N -> shrink N toward $80 (grow in from the right)
    766  f353		       c9 81		      cmp	#$81
    767  f355		       b0 07		      bcs	.entSlideStore	; still >= $81 -> entering
    768  f357		       a9 00		      lda	#0
    769  f359		       95 cd		      sta	entSlide,x	; reached $80 (or past) -> fully in, normal scroll
    770  f35b		       4c aa f3 	      jmp	.entNext
    771  f35e				   .entSlideStore
    772  f35e		       95 cd		      sta	entSlide,x
    773  f360		       4c aa f3 	      jmp	.entNext
    774  f363				   .entScroll
    775  f363		       b5 a3		      lda	entX,x
    776  f365		       38		      sec
    777  f366		       e5 b1		      sbc	scrollStep
    778  f368		       90 07		      bcc	.entEdge	; passed the left edge
    779  f36a		       f0 05		      beq	.entEdge	; reached x = 0
    780  f36c		       95 a3		      sta	entX,x
    781  f36e		       4c aa f3 	      jmp	.entNext
    782  f371				   .entEdge
    783  f371		       a9 00		      lda	#0
    784  f373		       95 a3		      sta	entX,x	; clamp at the left edge
    785  f375		       a9 01		      lda	#1
