    743  f379							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
    744  f379							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
    745  f379							;   (After examples/6-digit-score.asm.)
    746  f379							;-------------------------------------------------------------
    747  f379				   GetDigitPtrs
    748  f379		       a5 c1		      lda	gameState
    749  f37b		       d0 26		      bne	.goText
    750  f37d							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
    751  f37d		       a9 50		      lda	#<BlankGlyph
    752  f37f		       85 c8		      sta	Digit0+0
    753  f381		       85 ca		      sta	Digit0+2
    754  f383		       a2 04		      ldx	#4
    755  f385		       a0 01		      ldy	#1
    756  f387				   .gdpLoop
    757  f387		       b9 c2 00 	      lda	scoreBCD,y
    758  f38a		       29 f0		      and	#$f0	; high nibble * 16
    759  f38c		       4a		      lsr		; -> * 8
    760  f38d		       95 c8		      sta	Digit0,x
    761  f38f		       e8		      inx
    762  f390		       e8		      inx
    763  f391		       b9 c2 00 	      lda	scoreBCD,y
    764  f394		       29 0f		      and	#$0f	; low nibble
    765  f396		       0a		      asl
    766  f397		       0a		      asl
    767  f398		       0a		      asl		; * 8
    768  f399		       95 c8		      sta	Digit0,x
    769  f39b		       e8		      inx
    770  f39c		       e8		      inx
    771  f39d		       88		      dey
    772  f39e		       10 e7		      bpl	.gdpLoop
    773  f3a0		       4c ea f3 	      jmp	.setHi
    774  f3a3				   .goText
