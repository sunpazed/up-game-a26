    151 U00c8		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    152 U00ca		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    153 U00cb		       00	   animFrame  ds	1	; player run-cycle frame (0 or 1)
    154 U00cc		       00	   animTimer  ds	1	; frames left until the next player-frame swap
    155 U00cd		       00 00 00 00*entSlide   ds	6	; per-floor edge-slide state: 0 = normal; 1..7 = sliding
