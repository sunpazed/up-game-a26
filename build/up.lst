   1438  f956							;-------------------------------------------------------------
   1439  f956							; Player vertical-glide data
   1440  f956							;-------------------------------------------------------------
   1441  f956							; Band start scanline per floor (floor*30). 7 entries so [curFloor+1] is valid.
   1442  f956				   BandStartTab
   1443  f956		       00 1e 3c 5a*	      .byte.b	0, 30, 60, 90, 120, 150, 180
   1444  f95d
   1445  f95d							; Zero-padded player sprite for the pointer-offset free-Y draw. The kernel sets
   1446  f95d							; sprPtr = PlayerBuf + offset: offset 0 -> the 25 leading zeros (player not in
   1447  f95d							; this band, all blank); offset 1..36 slides the 12-byte body to the right
   1448  f95d							; content lines. Page-aligned so (sprPtr),Y never crosses a page boundary
   1449  f95d							; (keeps the per-line draw a constant 5 cycles).
   1450  fa00		       00 00 00 00*	      align	$100
   1451  fa00				   PlayerBuf
   1452  fa00		       00 00 00 00*	      ds	25, 0	; leading zeros (offset 0 = blank band)
   1453  fa19				   PlayerBody		; body row 0 = PlayerBuf + 25
   1454  fa19		       00 00 fc fc*	      .byte.b	$00,$00,$FC,$FC,$D4,$D4,$D4,$D4,$FC,$FC,$CC,$CC	; frame doubled (12 rows)
   1455  fa25		       00 00 00 00*	      ds	24, 0	; trailing zeros
   1456  fa3d
   1457  fa3d							;-------------------------------------------------------------
   1458  fa3d							; Vectors
   1459  fa3d							;-------------------------------------------------------------
   1460  fffc					      org	$fffc
   1461  fffc		       00 f0		      .word.w	Reset
   1462  fffe		       00 f0		      .word.w	Reset
