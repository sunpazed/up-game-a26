    872  f409							;-------------------------------------------------------------
    873  f409							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
    874  f409							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
    875  f409							;   (After examples/6-digit-score.asm.)
    876  f409							;-------------------------------------------------------------
    877  f409				   GetDigitPtrs
    878  f409		       a5 c2		      lda	gameState
    879  f40b		       d0 26		      bne	.goText
    880  f40d							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
    881  f40d		       a9 50		      lda	#<BlankGlyph
    882  f40f		       85 dd		      sta	Digit0+0
    883  f411		       85 df		      sta	Digit0+2
    884  f413		       a2 04		      ldx	#4
    885  f415		       a0 01		      ldy	#1
    886  f417				   .gdpLoop
    887  f417		       b9 c3 00 	      lda	scoreBCD,y
    888  f41a		       29 f0		      and	#$f0	; high nibble * 16
    889  f41c		       4a		      lsr		; -> * 8
    890  f41d		       95 dd		      sta	Digit0,x
    891  f41f		       e8		      inx
    892  f420		       e8		      inx
    893  f421		       b9 c3 00 	      lda	scoreBCD,y
    894  f424		       29 0f		      and	#$0f	; low nibble
    895  f426		       0a		      asl
    896  f427		       0a		      asl
    897  f428		       0a		      asl		; * 8
    898  f429		       95 dd		      sta	Digit0,x
    899  f42b		       e8		      inx
    900  f42c		       e8		      inx
    901  f42d		       88		      dey
    902  f42e		       10 e7		      bpl	.gdpLoop
    903  f430		       4c 7a f4 	      jmp	.setHi
    904  f433				   .goText
    905  f433							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
    906  f433		       a5 c8		      lda	goCnt
    907  f435		       c9 78		      cmp	#120
    908  f437		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
    909  f439							; "GAMEOVER" packed across the 6 glyph slots
    910  f439		       a9 58		      lda	#<GameOverGlyphs
    911  f43b		       85 dd		      sta	Digit0+0
    912  f43d		       18		      clc
    913  f43e		       69 08		      adc	#8
    914  f440		       85 df		      sta	Digit0+2
    915  f442		       69 08		      adc	#8
    916  f444		       85 e1		      sta	Digit0+4
    917  f446		       69 08		      adc	#8
    918  f448		       85 e3		      sta	Digit0+6
    919  f44a		       69 08		      adc	#8
    920  f44c		       85 e5		      sta	Digit0+8
    921  f44e		       69 08		      adc	#8
    922  f450		       85 e7		      sta	Digit0+10
    923  f452		       4c 7a f4 	      jmp	.setHi
    924  f455				   .goHi
    925  f455							; "HI" + the 4-digit high score
    926  f455		       a9 88		      lda	#<LetterH
    927  f457		       85 dd		      sta	Digit0+0
    928  f459		       a9 90		      lda	#<LetterI
    929  f45b		       85 df		      sta	Digit0+2
    930  f45d		       a2 04		      ldx	#4
    931  f45f		       a0 01		      ldy	#1
    932  f461				   .goHiLoop
    933  f461		       b9 c6 00 	      lda	hiScore,y
    934  f464		       29 f0		      and	#$f0
    935  f466		       4a		      lsr
    936  f467		       95 dd		      sta	Digit0,x
    937  f469		       e8		      inx
    938  f46a		       e8		      inx
    939  f46b		       b9 c6 00 	      lda	hiScore,y
    940  f46e		       29 0f		      and	#$0f
    941  f470		       0a		      asl
    942  f471		       0a		      asl
    943  f472		       0a		      asl
    944  f473		       95 dd		      sta	Digit0,x
    945  f475		       e8		      inx
    946  f476		       e8		      inx
    947  f477		       88		      dey
    948  f478		       10 e7		      bpl	.goHiLoop
    949  f47a				   .setHi
    950  f47a							; every glyph lives in the FontTable page, so all hi bytes are the same
    951  f47a		       a9 f7		      lda	#>FontTable
    952  f47c		       85 de		      sta	Digit0+1
    953  f47e		       85 e0		      sta	Digit0+3
