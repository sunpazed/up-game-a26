    843  f3eb							;-------------------------------------------------------------
    844  f3eb							; CalcQuickPos - A = x (0..159) -> A = quickPos
    845  f3eb							;   quickPos = (HMOVE fine nibble << 4) | delay count (low nibble).
    846  f3eb							;   Fast divide-by-15 + tables, from examples/hmove74.asm. Uses Y, tempOne.
    847  f3eb							;-------------------------------------------------------------
    848  f3eb				   CalcQuickPos
    849  f3eb		       85 85		      sta	tempOne
    850  f3ed		       4a		      lsr
    851  f3ee		       69 04		      adc	#4
    852  f3f0		       4a		      lsr
    853  f3f1		       4a		      lsr
    854  f3f2		       4a		      lsr
    855  f3f3		       65 85		      adc	tempOne
    856  f3f5		       6a		      ror
    857  f3f6		       4a		      lsr
    858  f3f7		       4a		      lsr
    859  f3f8		       4a		      lsr
    860  f3f9		       a8		      tay		; Y = x / 15
    861  f3fa		       b9 8f f4 	      lda	MultTab,y
    862  f3fd		       38		      sec
    863  f3fe		       e5 85		      sbc	tempOne
    864  f400		       0a		      asl
    865  f401		       0a		      asl
    866  f402		       0a		      asl
    867  f403		       0a		      asl
    868  f404		       18		      clc
    869  f405		       79 9a f4 	      adc	DelayTab,y
    870  f408		       60		      rts
