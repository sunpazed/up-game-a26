   1262  f85a							;-------------------------------------------------------------
   1263  f85a							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
   1264  f85a							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
   1265  f85a							;   (After examples/6-digit-score.asm.) Lives here in the trailing gap to
   1266  f85a							;   keep the cramped $f000-$f500 code region under the PosTblM0 org.
   1267  f85a							;-------------------------------------------------------------
   1268  f85a				   GetDigitPtrs
   1269  f85a		       a5 c5		      lda	gameState
   1270  f85c		       d0 26		      bne	.goText
   1271  f85e							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
   1272  f85e		       a9 50		      lda	#<BlankGlyph
   1273  f860		       85 e0		      sta	Digit0+0
   1274  f862		       85 e2		      sta	Digit0+2
   1275  f864		       a2 04		      ldx	#4
   1276  f866		       a0 01		      ldy	#1
   1277  f868				   .gdpLoop
   1278  f868		       b9 c6 00 	      lda	scoreBCD,y
   1279  f86b		       29 f0		      and	#$f0	; high nibble * 16
   1280  f86d		       4a		      lsr		; -> * 8
   1281  f86e		       95 e0		      sta	Digit0,x
   1282  f870		       e8		      inx
   1283  f871		       e8		      inx
   1284  f872		       b9 c6 00 	      lda	scoreBCD,y
   1285  f875		       29 0f		      and	#$0f	; low nibble
   1286  f877		       0a		      asl
   1287  f878		       0a		      asl
   1288  f879		       0a		      asl		; * 8
   1289  f87a		       95 e0		      sta	Digit0,x
   1290  f87c		       e8		      inx
   1291  f87d		       e8		      inx
   1292  f87e		       88		      dey
   1293  f87f		       10 e7		      bpl	.gdpLoop
   1294  f881		       4c cb f8 	      jmp	.setHi
   1295  f884				   .goText
   1296  f884							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
   1297  f884		       a5 cb		      lda	goCnt
   1298  f886		       c9 78		      cmp	#120
   1299  f888		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
   1300  f88a							; "GAMEOVER" packed across the 6 glyph slots
   1301  f88a		       a9 58		      lda	#<GameOverGlyphs
   1302  f88c		       85 e0		      sta	Digit0+0
   1303  f88e		       18		      clc
   1304  f88f		       69 08		      adc	#8
   1305  f891		       85 e2		      sta	Digit0+2
   1306  f893		       69 08		      adc	#8
   1307  f895		       85 e4		      sta	Digit0+4
   1308  f897		       69 08		      adc	#8
   1309  f899		       85 e6		      sta	Digit0+6
   1310  f89b		       69 08		      adc	#8
   1311  f89d		       85 e8		      sta	Digit0+8
   1312  f89f		       69 08		      adc	#8
   1313  f8a1		       85 ea		      sta	Digit0+10
   1314  f8a3		       4c cb f8 	      jmp	.setHi
   1315  f8a6				   .goHi
   1316  f8a6							; "HI" + the 4-digit high score
   1317  f8a6		       a9 88		      lda	#<LetterH
   1318  f8a8		       85 e0		      sta	Digit0+0
   1319  f8aa		       a9 90		      lda	#<LetterI
   1320  f8ac		       85 e2		      sta	Digit0+2
   1321  f8ae		       a2 04		      ldx	#4
   1322  f8b0		       a0 01		      ldy	#1
   1323  f8b2				   .goHiLoop
   1324  f8b2		       b9 c9 00 	      lda	hiScore,y
   1325  f8b5		       29 f0		      and	#$f0
   1326  f8b7		       4a		      lsr
   1327  f8b8		       95 e0		      sta	Digit0,x
   1328  f8ba		       e8		      inx
   1329  f8bb		       e8		      inx
   1330  f8bc		       b9 c9 00 	      lda	hiScore,y
   1331  f8bf		       29 0f		      and	#$0f
   1332  f8c1		       0a		      asl
   1333  f8c2		       0a		      asl
   1334  f8c3		       0a		      asl
   1335  f8c4		       95 e0		      sta	Digit0,x
   1336  f8c6		       e8		      inx
