    677  f2f0							; AnimatePlayer - tick the run-cycle frame. Swaps frame every animTimer
    678  f2f0							;   frames; the interval shortens with scroll speed so the player's legs
    679  f2f0							;   move faster as the world speeds up.
    680  f2f0							;   interval = ANIM_BASE - (scrollSpeed >> 3)
    681  f2f0							;-------------------------------------------------------------
