    850  f40b							;-------------------------------------------------------------
    851  f40b							; CalcQuickPos - A = x (0..159) -> A = quickPos
    852  f40b							;   quickPos = (HMOVE fine nibble << 4) | delay count (low nibble).
    853  f40b							;   Fast divide-by-15 + tables, from examples/hmove74.asm. Uses Y, tempOne.
    854  f40b							;-------------------------------------------------------------
    855  f40b				   CalcQuickPos
    856  f40b		       85 85		      sta	tempOne
    857  f40d		       4a		      lsr
    858  f40e		       69 04		      adc	#4
    859  f410		       4a		      lsr
    860  f411		       4a		      lsr
    861  f412		       4a		      lsr
    862  f413		       65 85		      adc	tempOne
    863  f415		       6a		      ror
    864  f416		       4a		      lsr
    865  f417		       4a		      lsr
    866  f418		       4a		      lsr
    867  f419		       a8		      tay		; Y = x / 15
    868  f41a		       b9 af f4 	      lda	MultTab,y
    869  f41d		       38		      sec
    870  f41e		       e5 85		      sbc	tempOne
    871  f420		       0a		      asl
    872  f421		       0a		      asl
    873  f422		       0a		      asl
    874  f423		       0a		      asl
    875  f424		       18		      clc
    876  f425		       79 ba f4 	      adc	DelayTab,y
    877  f428		       60		      rts
