    641  f2db							;-------------------------------------------------------------
    642  f2db							; UpdateWorld - scroll gaps left, wrap, and fall-through check
    643  f2db							;-------------------------------------------------------------
    644  f2db				   UpdateWorld
    645  f2db							; advance the PRNG once per frame so respawns stay varied
    646  f2db		       20 a3 f2 	      jsr	Rng
    647  f2de
    648  f2de							; Sub-pixel speed: accumulate the fractional speed; the carry is an
    649  f2de							; extra whole pixel this frame, so the scroll step is 1 or 2 px.
    650  f2de							; (scrollSpeed ramps with the score; see CheckCollision.)
    651  f2de		       a5 b0		      lda	scrollFrac
    652  f2e0		       18		      clc
    653  f2e1		       65 af		      adc	scrollSpeed	; accumulate 1/32-px units
    654  f2e3		       aa		      tax		; X = total (whole.frac)
    655  f2e4		       29 1f		      and	#$1F
    656  f2e6		       85 b0		      sta	scrollFrac	; carry the fraction (low 5 bits) to next frame
    657  f2e8		       8a		      txa
    658  f2e9		       4a		      lsr
    659  f2ea		       4a		      lsr
    660  f2eb		       4a		      lsr
    661  f2ec		       4a		      lsr
    662  f2ed		       4a		      lsr		; whole pixels this frame = total >> 5
    663  f2ee		       85 b1		      sta	scrollStep
    664  f2f0
    665  f2f0				   .scrollStep
    666  f2f0							; --- scroll gaps (floors 0..4 ; floor 5 has none) ---
    667  f2f0		       a2 04		      ldx	#4
    668  f2f2				   .gapLoop
    669  f2f2		       d6 8b		      dec	gapX,x
    670  f2f4		       d0 04		      bne	.gapNext	; reached 0 => wrap to the right
    671  f2f6		       a9 9f		      lda	#GAP_WRAP
    672  f2f8		       95 8b		      sta	gapX,x
    673  f2fa				   .gapNext
    674  f2fa		       ca		      dex
    675  f2fb		       10 f5		      bpl	.gapLoop
    676  f2fd
    677  f2fd							; --- entities: scroll, hide for a random delay, re-enter ---
    678  f2fd		       a2 05		      ldx	#5
    679  f2ff				   .entLoop
    680  f2ff		       b5 9d		      lda	entType,x
    681  f301		       f0 37		      beq	.entWaiting	; type 0 = hidden, waiting to respawn
    682  f303		       b5 cb		      lda	entSlide,x
    683  f305		       f0 25		      beq	.entScroll	; 0 -> normal scroll
    684  f307		       30 14		      bmi	.entSlideIn	; $80|N -> sliding IN from the right edge
    685  f309							; 1..7 -> sliding OUT the left edge (shift grows, then hide)
    686  f309		       f6 cb		      inc	entSlide,x	; advance the shift (per scroll step => speed-linked)
    687  f30b		       b5 cb		      lda	entSlide,x
    688  f30d		       c9 08		      cmp	#8
    689  f30f		       90 4d		      bcc	.entNext	; 1..7 still partly on-screen
    690  f311		       a9 00		      lda	#0
    691  f313		       95 9d		      sta	entType,x	; fully off the left edge -> hide + arm respawn
    692  f315		       95 cb		      sta	entSlide,x
    693  f317		       20 79 f3 	      jsr	SetRespawnDelay
    694  f31a		       4c 5e f3 	      jmp	.entNext
    695  f31d				   .entSlideIn
    696  f31d		       d6 cb		      dec	entSlide,x	; $80|N -> $80|(N-1): grow in from the right edge
    697  f31f		       b5 cb		      lda	entSlide,x
    698  f321		       c9 80		      cmp	#$80
    699  f323		       d0 39		      bne	.entNext	; still entering ($80|7 .. $80|1)
    700  f325		       a9 00		      lda	#0
    701  f327		       95 cb		      sta	entSlide,x	; N=0 -> fully in; normal scroll begins next step
    702  f329		       4c 5e f3 	      jmp	.entNext
    703  f32c				   .entScroll
    704  f32c							; normal scroll until the entity reaches the left edge (entX = 0)
    705  f32c		       b5 a3		      lda	entX,x
    706  f32e		       f0 05		      beq	.entStartSlide
    707  f330		       d6 a3		      dec	entX,x
    708  f332		       4c 5e f3 	      jmp	.entNext
    709  f335				   .entStartSlide
    710  f335		       f6 cb		      inc	entSlide,x	; 0 -> 1: hold at x=0, kernel now draws asl x1
    711  f337		       4c 5e f3 	      jmp	.entNext
    712  f33a				   .entWaiting
    713  f33a		       d6 a9		      dec	entDelay,x
    714  f33c		       d0 20		      bne	.entNext
    715  f33e							; delay elapsed -> respawn, but not over this floor's gap. If the gap
    716  f33e							; is in the spawn zone, wait a little and recheck (they scroll at the
    717  f33e							; same speed, so clearing them at spawn keeps them apart all pass).
    718  f33e		       b5 8b		      lda	gapX,x
    719  f340		       c9 91		      cmp	#GAP_SPAWN_CLEAR
    720  f342		       90 07		      bcc	.doSpawn
    721  f344		       a9 10		      lda	#ENT_DEFER
    722  f346		       95 a9		      sta	entDelay,x
    723  f348		       4c 5e f3 	      jmp	.entNext
    724  f34b				   .doSpawn
    725  f34b		       20 a3 f2 	      jsr	Rng
    726  f34e		       29 03		      and	#3
    727  f350		       a8		      tay
    728  f351		       b9 c0 f4 	      lda	EntTypeRoll,y
    729  f354		       95 9d		      sta	entType,x
    730  f356		       a9 98		      lda	#ENT_WRAP
    731  f358		       95 a3		      sta	entX,x
    732  f35a		       a9 87		      lda	#$80|7	; begin sliding IN from the right edge (reflected)
    733  f35c		       95 cb		      sta	entSlide,x
    734  f35e				   .entNext
    735  f35e		       ca		      dex
    736  f35f		       10 9e		      bpl	.entLoop
    737  f361
    738  f361		       c6 b1		      dec	scrollStep
    739  f363		       d0 8b		      bne	.scrollStep	; run the scroll 1 or 2 times this frame
    740  f365
    741  f365							; --- fall-through (once per frame): gap under the player? ---
    742  f365		       a5 80		      lda	playerFloor
    743  f367		       c9 05		      cmp	#5
    744  f369		       b0 0d		      bcs	.noFall	; bottom tier is solid/safe
    745  f36b		       aa		      tax
    746  f36c		       b5 8b		      lda	gapX,x
    747  f36e		       c9 13		      cmp	#FALL_HI+1
    748  f370		       b0 06		      bcs	.noFall	; gap is right of the player
    749  f372		       c9 0e		      cmp	#FALL_LO
    750  f374		       90 02		      bcc	.noFall	; gap is left of the player
    751  f376		       e6 80		      inc	playerFloor	; fall down one tier
    752  f378				   .noFall
    753  f378		       60		      rts
