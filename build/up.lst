     37  0000 ????	       00 0e	   COL_BG     =	$0E	; light grey background
     38  0000 ????	       00 c8	   COL_GREEN  =	$C8	; platform top (green)
     39  0000 ????	       00 06	   COL_GREY   =	$06	; platform underside (dark grey)
     40  0000 ????	       00 02	   COL_PLAYER =	$02	; player sprite (dark grey)
     41  0000 ????
     42  0000 ????	       00 0a	   PLAYER_X   =	10	; fixed horizontal position of the player
     43  0000 ????
     44  0000 ????	       00 0c	   HUD_LINES  =	12
     45  0000 ????	       00 06	   NUM_BANDS  =	6
     46  0000 ????	       00 08	   SPRITE_H   =	8	; sprite data rows. band = setbg 1 + gap pos 2 + entity
     47  0000 ????						;   pos 2 + sprite 14 (6 body rows x2 + 2 blank foot) +
     48  0000 ????						;   green 5 + grey 6 = 30. No dedicated air pad: the
     49  0000 ????						;   positioning lines above already show as background
     50  0000 ????						;   (gap + sprites are off there) and double as the air.
     51  0000 ????	       00 05	   BAND_GREEN =	5
     52  0000 ????	       00 06	   BAND_GREY  =	6
     53  0000 ????
     54  0000 ????	       00 08	   GAP_WIDTH  =	8	; missile gap width (NUSIZ0 = $30)
     55  0000 ????	       00 9f	   GAP_WRAP   =	159	; respawn x at the right edge (cycle-74 reaches 0..159)
     56  0000 ????	       00 0e	   FALL_LO    =	14	; gap-under-player window [FALL_LO..FALL_HI], centred on
     57  0000 ????	       00 12	   FALL_HI    =	18	;   ~15 (measured: gap fully under the player at gapX~15)
     58  0000 ????
     59  0000 ????						; entities (GRP1): one per platform, scroll right-to-left
     60  0000 ????	       00 01	   ENT_CONE   =	1	; gold collectible (+1 score)
     61  0000 ????	       00 02	   ENT_SKULL  =	2	; red hazard
     62  0000 ????	       00 2c	   COL_CONE   =	$2C	; gold / yellow
     63  0000 ????	       00 46	   COL_SKULL  =	$46	; red
     64  0000 ????	       00 98	   ENT_WRAP   =	152	; respawn x. Kept <=152 so the 8px GRP1 object never
     65  0000 ????						; reaches the wrap zone (153-159): an object there would
     66  0000 ????						; mod-160 wrap part of the sprite to the LEFT edge,
     67  0000 ????						; flashing the freshly-rerolled type at pixel 0.
     68  0000 ????	       00 20	   ENT_DELAY_MIN =	32	; off-screen wait before an entity re-enters:
     69  0000 ????	       00 7f	   ENT_DELAY_MASK =	$7f	;   ENT_DELAY_MIN + (rng & MASK) = 32..159 frames
     70  0000 ????	       00 91	   GAP_SPAWN_CLEAR =	145	; don't spawn an entity while this floor's gap is >= here
     71  0000 ????	       00 10	   ENT_DEFER  =	16	;   (it would overlap the spawn x); recheck after this many frames
     72  0000 ????
     73  0000 ????						; Scroll speed in 1/32-px fixed point. Per-frame step = (scrollFrac + scrollSpeed)
     74  0000 ????						; >> 5 whole pixels; the low 5 bits carry as the fraction. Keep SPEED_MAX <= 224
     75  0000 ????						; so scrollFrac (<=31) + scrollSpeed never overflows 8 bits.
     76  0000 ????	       00 20	   SPEED_BASE =	32	; base speed (= 1.0 px/frame)
     77  0000 ????	       00 01	   SPEED_INC  =	1	; per cone (= +0.125 px/frame; ~24 cones to top speed)
     78  0000 ????	       00 80	   SPEED_MAX  =	128	; cap (= 4.0 px/frame; <= the fall window so falls hold)
     79  0000 ????
     80  0000 ????						; Player run-cycle animation. The frame swaps every animTimer frames, and the
     81  0000 ????						; interval shortens with scroll speed: interval = ANIM_BASE - (scrollSpeed >> 3).
     82  0000 ????						; (scrollSpeed 32..128 -> interval 18..6 frames; keep ANIM_BASE > SPEED_MAX>>3.)
     83  0000 ????	       00 16	   ANIM_BASE  =	22
     84  0000 ????
     85  0000 ????	       00 42	   COL_GAMEOVER =	$42	; red background tint while game over
     86  0000 ????
     87  0000 ????						; HUD score (48-pixel 6-digit method, after examples/6-digit-score.asm)
     88  0000 ????	       00 03	   THREE_COPIES =	%011	; NUSIZ: 3 close copies (P0 + P1 interleaved = 6 digits)
     89  0000 ????	       00 00	   SCORE_COL  =	$00	; black digits on the grey background
     90  0000 ????	       00 24	   SCORE_SLEEP =	36	; positions the score block (RESP0/RESP1 timing)
     91  0000 ????	       00 17	   PLAYER_SLEEP =	23	; re-strobes the player P0 near PLAYER_X after the HUD
