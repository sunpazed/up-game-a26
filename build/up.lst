    721  f31c		       b5 cd		      lda	entSlide,x
    722  f31e		       f0 28		      beq	.entScroll	; 0 -> normal scroll
    723  f320		       30 13		      bmi	.entSlideIn	; $80|N -> sliding IN from the right edge
    724  f322							; 1..7 -> sliding OUT the left edge: grow the shift, hide once fully off
    725  f322		       18		      clc
    726  f323		       65 b1		      adc	scrollStep
    727  f325		       c9 08		      cmp	#8
    728  f327		       90 1a		      bcc	.entSlideStore	; 1..7 still partly on-screen
    729  f329		       a9 00		      lda	#0
    730  f32b		       95 9d		      sta	entType,x	; fully off the left edge -> hide + arm respawn
    731  f32d		       95 cd		      sta	entSlide,x
    732  f32f		       20 ae f3 	      jsr	SetRespawnDelay
    733  f332		       4c 8f f3 	      jmp	.entNext
    734  f335				   .entSlideIn
    735  f335		       38		      sec
    736  f336		       e5 b1		      sbc	scrollStep	; $80|N -> shrink N toward $80 (grow in from the right)
    737  f338		       c9 81		      cmp	#$81
    738  f33a		       b0 07		      bcs	.entSlideStore	; still >= $81 -> entering
    739  f33c		       a9 00		      lda	#0
    740  f33e		       95 cd		      sta	entSlide,x	; reached $80 (or past) -> fully in, normal scroll
    741  f340		       4c 8f f3 	      jmp	.entNext
    742  f343				   .entSlideStore
    743  f343		       95 cd		      sta	entSlide,x
    744  f345		       4c 8f f3 	      jmp	.entNext
    745  f348				   .entScroll
    746  f348		       b5 a3		      lda	entX,x
    747  f34a		       38		      sec
    748  f34b		       e5 b1		      sbc	scrollStep
    749  f34d		       90 07		      bcc	.entEdge	; passed the left edge
    750  f34f		       f0 05		      beq	.entEdge	; reached x = 0
    751  f351		       95 a3		      sta	entX,x
    752  f353		       4c 8f f3 	      jmp	.entNext
    753  f356				   .entEdge
    754  f356		       a9 00		      lda	#0
    755  f358		       95 a3		      sta	entX,x	; clamp at the left edge
    756  f35a		       a9 01		      lda	#1
