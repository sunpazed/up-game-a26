    762  f399							;-------------------------------------------------------------
    763  f399							; SetRespawnDelay - arm entDelay[X] with a randomised off-screen wait.
    764  f399							;-------------------------------------------------------------
    765  f399				   SetRespawnDelay
    766  f399		       20 c3 f2 	      jsr	Rng
    767  f39c		       29 7f		      and	#ENT_DELAY_MASK
    768  f39e		       18		      clc
    769  f39f		       69 20		      adc	#ENT_DELAY_MIN
    770  f3a1		       95 a9		      sta	entDelay,x
    771  f3a3		       60		      rts
    772  f3a4
    773  f3a4							;-------------------------------------------------------------
    774  f3a4							; CheckCollision - player vs the entity on the player's floor.
    775  f3a4							;   cone  -> +1 to the BCD score, entity consumed.
    776  f3a4							;   skull -> game over (freeze + red background).
    777  f3a4							;-------------------------------------------------------------
    778  f3a4				   CheckCollision
    779  f3a4		       a5 07		      lda	CXPPMM
    780  f3a6		       10 50		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    781  f3a8							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    782  f3a8							; entity on playerFloor. Act on its type.
    783  f3a8		       a6 80		      ldx	playerFloor
    784  f3aa		       b5 9d		      lda	entType,x
    785  f3ac		       f0 4a		      beq	.ccDone	; guard: no entity here
    786  f3ae		       c9 02		      cmp	#ENT_SKULL
    787  f3b0		       f0 28		      beq	.ccSkull
    788  f3b2							; cone collected: +1 (BCD). GetDigitPtrs shows scoreBCD+2 as the
    789  f3b2							; leftmost (most-significant) digits, so the +1 must land on the
    790  f3b2							; least-significant byte scoreBCD+0 and carry up toward +2.
    791  f3b2		       f8		      sed
    792  f3b3		       a5 c2		      lda	scoreBCD+0
    793  f3b5		       18		      clc
    794  f3b6		       69 01		      adc	#1
    795  f3b8		       85 c2		      sta	scoreBCD+0
    796  f3ba		       a5 c3		      lda	scoreBCD+1
    797  f3bc		       69 00		      adc	#0
    798  f3be		       85 c3		      sta	scoreBCD+1
    799  f3c0		       a5 c4		      lda	scoreBCD+2
    800  f3c2		       69 00		      adc	#0
    801  f3c4		       85 c4		      sta	scoreBCD+2
    802  f3c6		       d8		      cld
    803  f3c7		       a9 00		      lda	#0
    804  f3c9		       95 9d		      sta	entType,x	; cone consumed
    805  f3cb		       20 99 f3 	      jsr	SetRespawnDelay	; wait before a new entity enters this floor
    806  f3ce							; ramp the scroll speed (sub-pixel speed-up with score)
    807  f3ce		       a5 af		      lda	scrollSpeed
    808  f3d0		       c9 80		      cmp	#SPEED_MAX
    809  f3d2		       b0 24		      bcs	.ccDone	; already at max
    810  f3d4		       18		      clc
    811  f3d5		       69 01		      adc	#SPEED_INC
    812  f3d7		       85 af		      sta	scrollSpeed
    813  f3d9		       60		      rts
    814  f3da				   .ccSkull
    815  f3da		       a9 01		      lda	#1
    816  f3dc		       85 c1		      sta	gameState
    817  f3de		       a9 42		      lda	#COL_GAMEOVER
    818  f3e0		       85 09		      sta	COLUBK	; red tint; NewGame restores COL_BG on restart
    819  f3e2							; high score = max(hiScore, score) over the low 4 digits
    820  f3e2		       a5 c3		      lda	scoreBCD+1
    821  f3e4		       c5 c6		      cmp	hiScore+1
    822  f3e6		       90 10		      bcc	.ccDone	; score's high pair < hiScore's
    823  f3e8		       d0 06		      bne	.ccNewHi	; score's high pair > hiScore's
    824  f3ea		       a5 c2		      lda	scoreBCD+0
    825  f3ec		       c5 c5		      cmp	hiScore+0
    826  f3ee		       90 08		      bcc	.ccDone	; equal high pair, low pair lower
    827  f3f0				   .ccNewHi
    828  f3f0		       a5 c2		      lda	scoreBCD+0
    829  f3f2		       85 c5		      sta	hiScore+0
    830  f3f4		       a5 c3		      lda	scoreBCD+1
    831  f3f6		       85 c6		      sta	hiScore+1
    832  f3f8				   .ccDone
    833  f3f8		       60		      rts
