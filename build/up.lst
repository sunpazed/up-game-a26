    701  f303		       a2 04		      ldx	#4
    702  f305				   .gapLoop
    703  f305		       b5 8b		      lda	gapX,x
    704  f307		       38		      sec
    705  f308		       e5 b1		      sbc	scrollStep
    706  f30a		       90 02		      bcc	.gapWrap	; underflowed past 0 -> wrap in from the right
    707  f30c		       d0 03		      bne	.gapStore	; still > 0
    708  f30e				   .gapWrap		; A is 0 or the negative remainder; +GAP_WRAP re-enters
    709  f30e		       18		      clc
    710  f30f		       69 9f		      adc	#GAP_WRAP
    711  f311				   .gapStore
    712  f311		       95 8b		      sta	gapX,x
    713  f313		       ca		      dex
    714  f314		       10 ef		      bpl	.gapLoop
