   1371  f919				   .usCone		; two-note coin: low note then a higher one
   1372  f919		       a9 04		      lda	#SFX_TONE
   1373  f91b		       85 15		      sta	AUDC0
   1374  f91d		       a9 0a		      lda	#SFX_VOL
   1375  f91f		       85 19		      sta	AUDV0
   1376  f921		       a5 c3		      lda	sfxTimer
