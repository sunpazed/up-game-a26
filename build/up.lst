    675  f2ee							; advance the PRNG once per frame so respawns stay varied
    676  f2ee		       20 ae f2 	      jsr	Rng
    677  f2f1
    678  f2f1							; Sub-pixel speed: accumulate the fractional speed; the carry is an
    679  f2f1							; extra whole pixel this frame, so the scroll step is 1 or 2 px.
    680  f2f1							; (scrollSpeed ramps with the score; see CheckCollision.)
    681  f2f1		       a5 b0		      lda	scrollFrac
    682  f2f3		       18		      clc
    683  f2f4		       65 af		      adc	scrollSpeed	; accumulate 1/32-px units
    684  f2f6		       aa		      tax		; X = total (whole.frac)
    685  f2f7		       29 1f		      and	#$1F
    686  f2f9		       85 b0		      sta	scrollFrac	; carry the fraction (low 5 bits) to next frame
    687  f2fb		       8a		      txa
    688  f2fc		       4a		      lsr
    689  f2fd		       4a		      lsr
    690  f2fe		       4a		      lsr
    691  f2ff		       4a		      lsr
    692  f300		       4a		      lsr		; whole pixels this frame = total >> 5
    693  f301		       85 b1		      sta	scrollStep
    694  f303
    695  f303							; Everything below advances by scrollStep in ONE pass (O(1)) rather than a
    696  f303							; per-pixel loop, so the overscan cost stays flat as the speed ramps -- the
    697  f303							; per-pixel loop was up to 4x work at top speed and overran the overscan
    698  f303							; timer (causing the screen to roll, worst on the heavier cone-pickup frame).
    699  f303
