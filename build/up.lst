    598  f28d							; Pos74M0 - position Missile 0 at gap[curFloor] in one scanline.
    599  f28d							;   IN: Y = curFloor. Uses precomputed gapQuick / posJmpLo.
    600  f28d							;   Cycle-74 HMOVE: clean edge-to-edge positioning, no comb.
    601  f28d							;-------------------------------------------------------------
    602  f28d				   Pos74M0
    603  f28d		       b9 91 00 	      lda	gapQuick,y
    604  f290		       85 22		      sta	HMM0	; high nibble = fine motion (low nibble ignored)
    605  f292		       29 0f		      and	#$0F
    606  f294		       aa		      tax		; X = delay count
    607  f295		       b9 97 00 	      lda	posJmpLo,y
    608  f298		       85 89		      sta	posJmp
    609  f29a		       a9 f5		      lda	#>PosTblM0
    610  f29c		       85 8a		      sta	posJmp+1
    611  f29e		       85 02		      sta	WSYNC
    612  f2a0							; 9 cycles of dead time (matches hmove74 calibration)
    613  f2a0		       ea		      nop		; 2
    614  f2a1		       ea		      nop		; 2
    615  f2a2		       ea		      nop		; 2
    616  f2a3		       04 ea		      .byte.b	$04,$EA	; NOP zp (3 cycles)
    617  f2a5				   .wait74
    618  f2a5		       ca		      dex
    619  f2a6		       10 fd		      bpl	.wait74
    620  f2a8		       6c 89 00 	      jmp	(posJmp)	; into PosTblM0; strobes RESM0, HMOVE @ ~74, rts
    621  f2ab
    622  f2ab							;-------------------------------------------------------------
    623  f2ab							; Pos74P1 - position the entity sprite (GRP1) at ent[curFloor].
    624  f2ab							;   IN: Y = curFloor. Uses entQuick / entJmpLo. Same technique as
    625  f2ab							;   Pos74M0, but strobes RESP1 (PosTblP1) and uses HMP1.
    626  f2ab							;-------------------------------------------------------------
    627  f2ab				   Pos74P1
    628  f2ab		       b9 b2 00 	      lda	entQuick,y
    629  f2ae		       85 21		      sta	HMP1
    630  f2b0		       29 0f		      and	#$0F
    631  f2b2		       aa		      tax
    632  f2b3		       b9 b8 00 	      lda	entJmpLo,y
    633  f2b6		       85 89		      sta	posJmp
    634  f2b8		       a9 f6		      lda	#>PosTblP1
    635  f2ba		       85 8a		      sta	posJmp+1
    636  f2bc		       85 02		      sta	WSYNC
    637  f2be		       ea		      nop
    638  f2bf		       ea		      nop
    639  f2c0		       ea		      nop
    640  f2c1		       04 ea		      .byte.b	$04,$EA
    641  f2c3				   .wait74p
    642  f2c3		       ca		      dex
    643  f2c4		       10 fd		      bpl	.wait74p
    644  f2c6		       6c 89 00 	      jmp	(posJmp)	; into PosTblP1; strobes RESP1, HMOVE @ ~74, rts
