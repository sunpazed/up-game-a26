    762  f364		       e5 b1		      sbc	scrollStep	; advance the wait by this frame's step (speed-linked)
    763  f366		       90 07		      bcc	.entSpawn
    764  f368		       f0 05		      beq	.entSpawn
    765  f36a		       95 a9		      sta	entDelay,x
