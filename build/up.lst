     18  f0bd		       ea		      nop
     17  f0bd					      REPEND
     18  f0be		       ea		      nop
     19  f0bf					      REPEND
    289  f0bf		       85 10		      sta	RESP0	; coarse-position P0 and P1 together
    290  f0c1		       85 11		      sta	RESP1
    291  f0c3		       85 2b		      sta	HMCLR	; clear stray motion (player left HMP0=$80)
    292  f0c5		       a9 10		      lda	#$10
