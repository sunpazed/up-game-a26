    998  f4b7							; Entity sprite rows (bottom row first), defined as symbols so the base sprites
    999  f4b7							; AND the left/right slide shift tables (all in page f5, below) generate from the
   1000  f4b7							; SAME source and never drift. Edit these rows to change the cone / skull art.
   1001  f4b7		       00 00	   CONE0      =	%00000000
   1002  f4b7		       00 00	   CONE1      =	%00000000
   1003  f4b7		       00 ff	   CONE2      =	%11111111	; wide base
   1004  f4b7		       00 42	   CONE3      =	%01000010
