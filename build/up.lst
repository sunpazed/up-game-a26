    851  f3d4		       a5 07		      lda	CXPPMM
    852  f3d6		       10 60		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    853  f3d8							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    854  f3d8							; entity on playerFloor. Act on its type.
    855  f3d8		       a6 80		      ldx	playerFloor
    856  f3da		       b5 9d		      lda	entType,x
