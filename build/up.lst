    828  f3d9							;-------------------------------------------------------------
    829  f3d9							; CheckRestart - during game over, a fresh fire press restarts.
    830  f3d9							;-------------------------------------------------------------
    831  f3d9				   CheckRestart
    832  f3d9		       a2 00		      ldx	#0
    833  f3db		       a5 0c		      lda	INPT4
    834  f3dd		       30 09		      bmi	.crStore	; not pressed
    835  f3df		       a2 01		      ldx	#1
    836  f3e1		       a5 82		      lda	btnPrev
    837  f3e3		       d0 03		      bne	.crStore	; held since last frame -> no edge
    838  f3e5		       4c 2b f0 	      jmp	NewGame	; fresh press -> restart (keeps hiScore)
    839  f3e8				   .crStore
