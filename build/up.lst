    650  f2ff							;-------------------------------------------------------------
    651  f2ff							; CheckCollision - player vs the entity on the player's floor.
    652  f2ff							;   cone  -> +1 to the BCD score, entity consumed.
    653  f2ff							;   skull -> game over (freeze + red background).
    654  f2ff							;-------------------------------------------------------------
    655  f2ff				   CheckCollision
    656  f2ff		       a5 07		      lda	CXPPMM
    657  f301		       10 50		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    658  f303							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    659  f303							; entity on playerFloor. Act on its type.
    660  f303		       a6 80		      ldx	playerFloor
    661  f305		       b5 9d		      lda	entType,x
    662  f307		       f0 4a		      beq	.ccDone	; guard: no entity here
    663  f309		       c9 02		      cmp	#ENT_SKULL
    664  f30b		       f0 28		      beq	.ccSkull
    665  f30d							; cone collected: +1 (BCD). GetDigitPtrs shows scoreBCD+2 as the
    666  f30d							; leftmost (most-significant) digits, so the +1 must land on the
    667  f30d							; least-significant byte scoreBCD+0 and carry up toward +2.
    668  f30d		       f8		      sed
    669  f30e		       a5 c2		      lda	scoreBCD+0
    670  f310		       18		      clc
    671  f311		       69 01		      adc	#1
    672  f313		       85 c2		      sta	scoreBCD+0
    673  f315		       a5 c3		      lda	scoreBCD+1
    674  f317		       69 00		      adc	#0
    675  f319		       85 c3		      sta	scoreBCD+1
    676  f31b		       a5 c4		      lda	scoreBCD+2
    677  f31d		       69 00		      adc	#0
    678  f31f		       85 c4		      sta	scoreBCD+2
    679  f321		       d8		      cld
    680  f322		       a9 00		      lda	#0
    681  f324		       95 9d		      sta	entType,x	; cone consumed
    682  f326		       20 f4 f2 	      jsr	SetRespawnDelay	; wait before a new entity enters this floor
    683  f329							; ramp the scroll speed (sub-pixel speed-up with score)
    684  f329		       a5 af		      lda	scrollSpeed
    685  f32b		       c9 80		      cmp	#SPEED_MAX
    686  f32d		       b0 24		      bcs	.ccDone	; already at max
    687  f32f		       18		      clc
    688  f330		       69 01		      adc	#SPEED_INC
    689  f332		       85 af		      sta	scrollSpeed
    690  f334		       60		      rts
    691  f335				   .ccSkull
    692  f335		       a9 01		      lda	#1
    693  f337		       85 c1		      sta	gameState
    694  f339		       a9 42		      lda	#COL_GAMEOVER
    695  f33b		       85 09		      sta	COLUBK	; red tint; NewGame restores COL_BG on restart
    696  f33d							; high score = max(hiScore, score) over the low 4 digits
    697  f33d		       a5 c3		      lda	scoreBCD+1
    698  f33f		       c5 c6		      cmp	hiScore+1
    699  f341		       90 10		      bcc	.ccDone	; score's high pair < hiScore's
    700  f343		       d0 06		      bne	.ccNewHi	; score's high pair > hiScore's
    701  f345		       a5 c2		      lda	scoreBCD+0
    702  f347		       c5 c5		      cmp	hiScore+0
    703  f349		       90 08		      bcc	.ccDone	; equal high pair, low pair lower
    704  f34b				   .ccNewHi
    705  f34b		       a5 c2		      lda	scoreBCD+0
    706  f34d		       85 c5		      sta	hiScore+0
    707  f34f		       a5 c3		      lda	scoreBCD+1
    708  f351		       85 c6		      sta	hiScore+1
    709  f353				   .ccDone
    710  f353		       60		      rts
