    208  f031				   NewGame
    209  f031		       a9 0e		      lda	#COL_BG
    210  f033		       85 09		      sta	COLUBK	; clear any game-over red tint
    211  f035
    212  f035		       a9 05		      lda	#5
    213  f037		       85 80		      sta	playerFloor	; player starts on the bottom tier
    214  f039		       a9 00		      lda	#0
    215  f03b		       85 82		      sta	btnPrev
    216  f03d		       85 c4		      sta	gameState
    217  f03f		       85 ca		      sta	goCnt
