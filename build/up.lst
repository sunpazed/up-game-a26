   1210  f85a							;-------------------------------------------------------------
   1211  f85a							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
   1212  f85a							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
   1213  f85a							;   (After examples/6-digit-score.asm.) Lives here in the trailing gap to
   1214  f85a							;   keep the cramped $f000-$f500 code region under the PosTblM0 org.
   1215  f85a							;-------------------------------------------------------------
   1216  f85a				   GetDigitPtrs
   1217  f85a		       a5 c4		      lda	gameState
   1218  f85c		       d0 26		      bne	.goText
   1219  f85e							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
   1220  f85e		       a9 50		      lda	#<BlankGlyph
   1221  f860		       85 df		      sta	Digit0+0
   1222  f862		       85 e1		      sta	Digit0+2
   1223  f864		       a2 04		      ldx	#4
   1224  f866		       a0 01		      ldy	#1
   1225  f868				   .gdpLoop
   1226  f868		       b9 c5 00 	      lda	scoreBCD,y
   1227  f86b		       29 f0		      and	#$f0	; high nibble * 16
   1228  f86d		       4a		      lsr		; -> * 8
   1229  f86e		       95 df		      sta	Digit0,x
   1230  f870		       e8		      inx
   1231  f871		       e8		      inx
   1232  f872		       b9 c5 00 	      lda	scoreBCD,y
   1233  f875		       29 0f		      and	#$0f	; low nibble
   1234  f877		       0a		      asl
   1235  f878		       0a		      asl
   1236  f879		       0a		      asl		; * 8
   1237  f87a		       95 df		      sta	Digit0,x
   1238  f87c		       e8		      inx
   1239  f87d		       e8		      inx
   1240  f87e		       88		      dey
   1241  f87f		       10 e7		      bpl	.gdpLoop
   1242  f881		       4c cb f8 	      jmp	.setHi
   1243  f884				   .goText
   1244  f884							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
   1245  f884		       a5 ca		      lda	goCnt
   1246  f886		       c9 78		      cmp	#120
   1247  f888		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
   1248  f88a							; "GAMEOVER" packed across the 6 glyph slots
   1249  f88a		       a9 58		      lda	#<GameOverGlyphs
   1250  f88c		       85 df		      sta	Digit0+0
   1251  f88e		       18		      clc
   1252  f88f		       69 08		      adc	#8
   1253  f891		       85 e1		      sta	Digit0+2
   1254  f893		       69 08		      adc	#8
   1255  f895		       85 e3		      sta	Digit0+4
   1256  f897		       69 08		      adc	#8
   1257  f899		       85 e5		      sta	Digit0+6
   1258  f89b		       69 08		      adc	#8
   1259  f89d		       85 e7		      sta	Digit0+8
   1260  f89f		       69 08		      adc	#8
   1261  f8a1		       85 e9		      sta	Digit0+10
   1262  f8a3		       4c cb f8 	      jmp	.setHi
   1263  f8a6				   .goHi
   1264  f8a6							; "HI" + the 4-digit high score
   1265  f8a6		       a9 88		      lda	#<LetterH
   1266  f8a8		       85 df		      sta	Digit0+0
   1267  f8aa		       a9 90		      lda	#<LetterI
   1268  f8ac		       85 e1		      sta	Digit0+2
   1269  f8ae		       a2 04		      ldx	#4
   1270  f8b0		       a0 01		      ldy	#1
   1271  f8b2				   .goHiLoop
   1272  f8b2		       b9 c8 00 	      lda	hiScore,y
   1273  f8b5		       29 f0		      and	#$f0
   1274  f8b7		       4a		      lsr
   1275  f8b8		       95 df		      sta	Digit0,x
   1276  f8ba		       e8		      inx
   1277  f8bb		       e8		      inx
   1278  f8bc		       b9 c8 00 	      lda	hiScore,y
   1279  f8bf		       29 0f		      and	#$0f
   1280  f8c1		       0a		      asl
   1281  f8c2		       0a		      asl
   1282  f8c3		       0a		      asl
   1283  f8c4		       95 df		      sta	Digit0,x
   1284  f8c6		       e8		      inx
   1285  f8c7		       e8		      inx
   1286  f8c8		       88		      dey
   1287  f8c9		       10 e7		      bpl	.goHiLoop
   1288  f8cb				   .setHi
   1289  f8cb							; every glyph lives in the FontTable page, so all hi bytes are the same
   1290  f8cb		       a9 f7		      lda	#>FontTable
   1291  f8cd		       85 e0		      sta	Digit0+1
   1292  f8cf		       85 e2		      sta	Digit0+3
   1293  f8d1		       85 e4		      sta	Digit0+5
   1294  f8d3		       85 e6		      sta	Digit0+7
   1295  f8d5		       85 e8		      sta	Digit0+9
   1296  f8d7		       85 ea		      sta	Digit0+11
   1297  f8d9		       60		      rts
   1298  f8da
   1299  f8da							;-------------------------------------------------------------
   1300  f8da							; UpdateSound - advance the one-shot SFX on channel 0 (called every frame in
   1301  f8da							;   all game states, so the death sound keeps playing through the freeze).
   1302  f8da							;   sfxTimer counts down; AUDC0/AUDF0/AUDV0 are derived from the id + timer.
   1303  f8da							;-------------------------------------------------------------
   1304  f8da				   UpdateSound
   1305  f8da		       a5 c3		      lda	sfxTimer
   1306  f8dc		       d0 01		      bne	.usPlay
   1307  f8de		       60		      rts		; idle (already silent)
   1308  f8df				   .usPlay
   1309  f8df		       c6 c3		      dec	sfxTimer
   1310  f8e1		       f0 11		      beq	.usSilence	; last frame elapsed -> turn the channel off
   1311  f8e3		       a5 c2		      lda	sfxId
   1312  f8e5		       c9 01		      cmp	#SFX_JUMP
   1313  f8e7		       f0 10		      beq	.usJump
   1314  f8e9		       c9 02		      cmp	#SFX_DROP
   1315  f8eb		       f0 1c		      beq	.usDrop
   1316  f8ed		       c9 03		      cmp	#SFX_CONE
   1317  f8ef		       f0 28		      beq	.usCone
   1318  f8f1		       4c 31 f9 	      jmp	.usDeath
   1319  f8f4				   .usSilence
   1320  f8f4		       a9 00		      lda	#0
   1321  f8f6		       85 19		      sta	AUDV0
   1322  f8f8		       60		      rts
   1323  f8f9
   1324  f8f9				   .usJump		; pure tone, pitch RISES (AUDF falls as timer falls)
   1325  f8f9		       a9 04		      lda	#SFX_TONE
   1326  f8fb		       85 15		      sta	AUDC0
   1327  f8fd		       a5 c3		      lda	sfxTimer
   1328  f8ff		       18		      clc
   1329  f900		       69 03		      adc	#3
   1330  f902		       85 17		      sta	AUDF0
   1331  f904		       a9 0a		      lda	#SFX_VOL
   1332  f906		       85 19		      sta	AUDV0
   1333  f908		       60		      rts
   1334  f909
   1335  f909				   .usDrop		; pure tone, pitch FALLS (AUDF rises as timer falls)
   1336  f909		       a9 04		      lda	#SFX_TONE
   1337  f90b		       85 15		      sta	AUDC0
   1338  f90d		       a9 0c		      lda	#DROP_DUR
   1339  f90f		       38		      sec
   1340  f910		       e5 c3		      sbc	sfxTimer
   1341  f912		       85 17		      sta	AUDF0
   1342  f914		       a9 0a		      lda	#SFX_VOL
   1343  f916		       85 19		      sta	AUDV0
   1344  f918		       60		      rts
   1345  f919
   1346  f919				   .usCone		; two-note coin: low note then a higher one
   1347  f919		       a9 04		      lda	#SFX_TONE
   1348  f91b		       85 15		      sta	AUDC0
   1349  f91d		       a9 0a		      lda	#SFX_VOL
   1350  f91f		       85 19		      sta	AUDV0
   1351  f921		       a5 c3		      lda	sfxTimer
   1352  f923		       c9 08		      cmp	#CONE_DUR/2
   1353  f925		       b0 05		      bcs	.usConeLo	; first half -> low note
   1354  f927		       a9 07		      lda	#7	; second half -> higher note (lower AUDF)
   1355  f929		       85 17		      sta	AUDF0
   1356  f92b		       60		      rts
   1357  f92c				   .usConeLo
   1358  f92c		       a9 0d		      lda	#13
   1359  f92e		       85 17		      sta	AUDF0
   1360  f930		       60		      rts
   1361  f931
   1362  f931				   .usDeath		; white noise: "tah" burst, gap, "tish" burst
   1363  f931		       a9 08		      lda	#SFX_NOISE
   1364  f933		       85 15		      sta	AUDC0
   1365  f935		       a5 c3		      lda	sfxTimer
   1366  f937		       c9 0d		      cmp	#13
   1367  f939		       b0 09		      bcs	.usDeathTah	; 13.. -> first (lower) burst
   1368  f93b		       c9 0a		      cmp	#10
   1369  f93d		       90 0e		      bcc	.usDeathTish	; ..9	-> second (sharper) burst
   1370  f93f		       a9 00		      lda	#0	; 10..12 -> short gap
   1371  f941		       85 19		      sta	AUDV0
   1372  f943		       60		      rts
   1373  f944				   .usDeathTah
   1374  f944		       a9 0f		      lda	#15
   1375  f946		       85 17		      sta	AUDF0
   1376  f948		       a9 0a		      lda	#SFX_VOL
   1377  f94a		       85 19		      sta	AUDV0
   1378  f94c		       60		      rts
   1379  f94d				   .usDeathTish
   1380  f94d		       a9 04		      lda	#4
   1381  f94f		       85 17		      sta	AUDF0
   1382  f951		       a9 0a		      lda	#SFX_VOL
   1383  f953		       85 19		      sta	AUDV0
   1384  f955		       60		      rts
