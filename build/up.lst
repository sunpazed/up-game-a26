     33  0000 ????
     34  0000 ????						;-------------------------------------------------------------
     35  0000 ????						; Constants
     36  0000 ????						;-------------------------------------------------------------
     37  0000 ????	       00 0e	   COL_BG     =	$0E	; light grey background
     38  0000 ????	       00 c8	   COL_GREEN  =	$C8	; platform top (green)
     39  0000 ????	       00 06	   COL_GREY   =	$06	; platform underside (dark grey)
     40  0000 ????	       00 02	   COL_PLAYER =	$02	; player sprite (dark grey)
     41  0000 ????
     42  0000 ????	       00 0a	   PLAYER_X   =	10	; fixed horizontal position of the player
     43  0000 ????	       00 07	   PREST_OFF  =	7	; player rest top = floor*30 + 7 (band-local sprite top)
     44  0000 ????	       00 03	   PLERP      =	3	; player vertical glide speed (px/frame toward restY)
     45  0000 ????
     46  0000 ????	       00 0c	   HUD_LINES  =	12
     47  0000 ????	       00 06	   NUM_BANDS  =	6
     48  0000 ????	       00 08	   SPRITE_H   =	8	; sprite data rows. band = setbg 1 + gap pos 2 + entity
     49  0000 ????						;   pos 2 + sprite 14 (6 body rows x2 + 2 blank foot) +
     50  0000 ????						;   green 5 + grey 6 = 30. No dedicated air pad: the
     51  0000 ????						;   positioning lines above already show as background
     52  0000 ????						;   (gap + sprites are off there) and double as the air.
     53  0000 ????	       00 05	   BAND_GREEN =	5
     54  0000 ????	       00 06	   BAND_GREY  =	6
     55  0000 ????
     56  0000 ????	       00 08	   GAP_WIDTH  =	8	; missile gap width (NUSIZ0 = $30)
     57  0000 ????	       00 9f	   GAP_WRAP   =	159	; respawn x at the right edge (cycle-74 reaches 0..159).
     58  0000 ????						; Gaps always re-enter here (slide in from the edge); the
     59  0000 ????						; per-game variety comes from the randomised START layout.
     60  0000 ????	       00 18	   GAP_MIN_SEP =	24	; min x-distance between adjacent floors' start gaps, so
     61  0000 ????						; holes never stack (= drop the player straight through)
     62  0000 ????	       00 08	   FALL_LO    =	8	; gap-under-player window [FALL_LO..FALL_HI], centred on
     63  0000 ????	       00 0e	   FALL_HI    =	14	;   ~15 (measured: gap fully under the player at gapX~15)
     64  0000 ????
     65  0000 ????						; entities (GRP1): one per platform, scroll right-to-left
     66  0000 ????	       00 01	   ENT_CONE   =	1	; gold collectible (+1 score)
     67  0000 ????	       00 02	   ENT_SKULL  =	2	; red hazard
     68  0000 ????	       00 2c	   COL_CONE   =	$2C	; gold / yellow
     69  0000 ????	       00 46	   COL_SKULL  =	$46	; red
     70  0000 ????	       00 98	   ENT_WRAP   =	152	; respawn x. Kept <=152 so the 8px GRP1 object never
     71  0000 ????						; reaches the wrap zone (153-159): an object there would
     72  0000 ????						; mod-160 wrap part of the sprite to the LEFT edge,
     73  0000 ????						; flashing the freshly-rerolled type at pixel 0.
     74  0000 ????	       00 20	   ENT_DELAY_MIN =	32	; off-screen wait before an entity re-enters:
     75  0000 ????	       00 7f	   ENT_DELAY_MASK =	$7f	;   ENT_DELAY_MIN + (rng & MASK) = 32..159 frames
     76  0000 ????	       00 91	   GAP_SPAWN_CLEAR =	145	; don't spawn an entity while this floor's gap is >= here
     77  0000 ????	       00 10	   ENT_DEFER  =	16	;   (it would overlap the spawn x); recheck after this many frames
     78  0000 ????
     79  0000 ????						; Scroll speed in 1/32-px fixed point. Per-frame step = (scrollFrac + scrollSpeed)
     80  0000 ????						; >> 5 whole pixels; the low 5 bits carry as the fraction. Keep SPEED_MAX <= 224
     81  0000 ????						; so scrollFrac (<=31) + scrollSpeed never overflows 8 bits.
     82  0000 ????	       00 20	   SPEED_BASE =	32	; base speed (= 1.0 px/frame)
     83  0000 ????	       00 02	   SPEED_INC  =	2	; per cone (= +0.125 px/frame; ~24 cones to top speed)
     84  0000 ????	       00 60	   SPEED_MAX  =	96	; cap (= 4.0 px/frame; <= the fall window so falls hold)
     85  0000 ????
     86  0000 ????						; Player run-cycle animation. The frame swaps every animTimer frames, and the
     87  0000 ????						; interval shortens with scroll speed: interval = ANIM_BASE - (scrollSpeed >> 3).
     88  0000 ????						; (scrollSpeed 32..128 -> interval 18..6 frames; keep ANIM_BASE > SPEED_MAX>>3.)
     89  0000 ????	       00 16	   ANIM_BASE  =	22
     90  0000 ????
     91  0000 ????	       00 42	   COL_GAMEOVER =	$42	; red background tint while game over
     92  0000 ????
     93  0000 ????						; HUD score (48-pixel 6-digit method, after examples/6-digit-score.asm)
     94  0000 ????	       00 03	   THREE_COPIES =	%011	; NUSIZ: 3 close copies (P0 + P1 interleaved = 6 digits)
     95  0000 ????	       00 00	   SCORE_COL  =	$00	; black digits on the grey background
     96  0000 ????	       00 24	   SCORE_SLEEP =	36	; positions the score block (RESP0/RESP1 timing)
     97  0000 ????	       00 17	   PLAYER_SLEEP =	23	; re-strobes the player P0 near PLAYER_X after the HUD
     98  0000 ????
     99  0000 ????						; Sound effects (TIA channel 0). A frame-timed engine plays one SFX at a time:
    100  0000 ????						; sfxId picks the sound, sfxTimer counts its remaining frames (see UpdateSound).
    101  0000 ????	       00 01	   SFX_JUMP   =	1	; rising tone
    102  0000 ????	       00 02	   SFX_DROP   =	2	; falling tone
    103  0000 ????	       00 03	   SFX_CONE   =	3	; two-note coin pickup
    104  0000 ????	       00 04	   SFX_DEATH  =	4	; two white-noise bursts
    105  0000 ????	       00 0c	   JUMP_DUR   =	12
    106  0000 ????	       00 0c	   DROP_DUR   =	12
    107  0000 ????	       00 10	   CONE_DUR   =	16
    108  0000 ????	       00 14	   DEATH_DUR  =	20
    109  0000 ????	       00 04	   SFX_TONE   =	$04	; pure-tone waveform (AUDC0)
    110  0000 ????	       00 08	   SFX_NOISE  =	$08	; white-noise waveform (AUDC0)
    111  0000 ????	       00 0a	   SFX_VOL    =	$0A	; SFX volume (AUDV0, 0-15)
    112  0000 ????
    113  0000 ????				      MAC	trigger_sfx
    114  0000 ????				      lda	#{1}
    115  0000 ????				      sta	sfxId
    116  0000 ????				      lda	#{2}
    117  0000 ????				      sta	sfxTimer
    118  0000 ????				      ENDM		; {1} = SFX id, {2} = duration in frames
