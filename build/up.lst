    118 U00b8		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    119 U00be		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    120 U00c0		       00	   rng	      ds	1	; PRNG state (LFSR)
    121 U00c1		       00	   frameCnt   ds	1	; free-running frame counter (never reset; RNG reseed)
    122 U00c2		       00	   gameState  ds	1	; 0 = playing, 1 = game over
    123 U00c3		       00 00 00    scoreBCD   ds	3	; BCD score (low 4 digits shown)
    124 U00c6		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    125 U00c8		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    126 U00c9		       00	   animFrame  ds	1	; player run-cycle frame (0 or 1)
    127 U00ca		       00	   animTimer  ds	1	; frames left until the next player-frame swap
