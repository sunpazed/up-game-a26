    835  f3f9							;-------------------------------------------------------------
    836  f3f9							; CheckRestart - during game over, a fresh fire press restarts.
    837  f3f9							;-------------------------------------------------------------
    838  f3f9				   CheckRestart
    839  f3f9		       a2 00		      ldx	#0
    840  f3fb		       a5 0c		      lda	INPT4
    841  f3fd		       30 09		      bmi	.crStore	; not pressed
    842  f3ff		       a2 01		      ldx	#1
    843  f401		       a5 82		      lda	btnPrev
    844  f403		       d0 03		      bne	.crStore	; held since last frame -> no edge
    845  f405		       4c 2b f0 	      jmp	NewGame	; fresh press -> restart (keeps hiScore)
    846  f408				   .crStore
    847  f408		       86 82		      stx	btnPrev
    848  f40a		       60		      rts
