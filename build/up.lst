    117 U00ec ????				      SEG.U	vars
    118 U0080					      org	$80
    119 U0080
    120 U0080		       00	   playerFloor ds	1	; 0 = top tier .. 5 = bottom tier
    121 U0081		       00	   playerBandCount ds	1	; bandCount value at which to draw the player
    122 U0082		       00	   btnPrev    ds	1	; fire button state last frame (edge detect)
    123 U0083		       00	   bandCount  ds	1	; bands remaining in the visible kernel
    124 U0084		       00	   curFloor   ds	1	; floor index of the band being drawn
    125 U0085		       00	   tempOne    ds	1	; scratch for the fast divide in CalcQuickPos
    126 U0086		       00	   tempFloor  ds	1	; scratch floor index across CalcQuickPos
    127 U0087		       00 00	   sprPtr     ds	2	; pointer to current band's sprite data
    128 U0089		       00 00	   posJmp     ds	2	; indirect pointer into the missile strobe table
    129 U008b		       00 00 00 00*gapX       ds	6	; per-floor gap x position (floor 5 unused/no gap)
    130 U0091		       00 00 00 00*gapQuick   ds	6	; per-floor precomputed quickPos (HMM0 fine | delay count)
    131 U0097		       00 00 00 00*posJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    132 U009d		       00 00 00 00*entType    ds	6	; per-floor entity: 0 none/hidden, 1 cone, 2 skull
    133 U00a3		       00 00 00 00*entX       ds	6	; per-floor entity x position
    134 U00a9		       00 00 00 00*entDelay   ds	6	; per-floor frames left to wait off-screen before respawn
    135 U00af		       00	   scrollSpeed ds	1	; fractional scroll speed (ramps with score)
    136 U00b0		       00	   scrollFrac ds	1	; fixed-point fractional accumulator
    137 U00b1		       00	   scrollStep ds	1	; whole pixels to scroll this frame
    138 U00b2		       00 00 00 00*entQuick   ds	6	; per-floor precomputed quickPos for the entity (GRP1)
    139 U00b8		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    140 U00be		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    141 U00c0		       00	   rng	      ds	1	; PRNG state (LFSR)
    142 U00c1		       00	   frameCnt   ds	1	; free-running frame counter (never reset; RNG reseed)
    143 U00c2		       00	   sfxId      ds	1	; sound effect currently playing (0 = none)
    144 U00c3		       00	   sfxTimer   ds	1	; frames left in the current sound effect
    145 U00c4		       00	   gameState  ds	1	; 0 = playing, 1 = game over
    146 U00c5		       00 00 00    scoreBCD   ds	3	; BCD score (low 4 digits shown)
    147 U00c8		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    148 U00ca		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    149 U00cb		       00	   animFrame  ds	1	; player run-cycle frame (0 or 1)
    150 U00cc		       00	   animTimer  ds	1	; frames left until the next player-frame swap
    151 U00cd		       00 00 00 00*entSlide   ds	6	; per-floor edge-slide state: 0 = normal; 1..7 = sliding
    152 U00d3							;   OUT the LEFT edge (asl amount); $80|N = sliding IN
    153 U00d3							;   the RIGHT edge (asl amount N, reflected via REFP1)
    154 U00d3		       00 00 00 00*entDrawLo  ds	6	; per-floor resolved entity sprite low byte (base or shift)
    155 U00d9		       00 00 00 00*entRefp    ds	6	; per-floor REFP1 value ($08 while sliding in, else $00)
    156 U00df		       00 00 00 00*Digit0     ds	12	; 6 font pointers (Digit0..Digit5) for the score kernel
    157 U00eb		       00	   loopCnt    ds	1	; scanline counter inside DrawDigits
