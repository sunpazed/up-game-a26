   1006  f4b7		       00 24	   CONE5      =	%00100100
   1007  f4b7		       00 18	   CONE6      =	%00011000
   1008  f4b7		       00 18	   CONE7      =	%00011000	; point (top)
   1009  f4b7		       00 00	   SKULL0     =	%00000000
   1010  f4b7		       00 00	   SKULL1     =	%00000000
   1011  f4b7		       00 3c	   SKULL2     =	%00111100
   1012  f4b7		       00 7e	   SKULL3     =	%01111110
   1013  f4b7		       00 e7	   SKULL4     =	%11100111	; eyes
   1014  f4b7		       00 bd	   SKULL5     =	%10111101
   1015  f4b7		       00 7e	   SKULL6     =	%01111110
   1016  f4b7		       00 3c	   SKULL7     =	%00111100	; top
   1017  f4b7
   1018  f4b7					      MAC	cone_rows
   1019  f4b7					      .byte	(CONE0<<{1})&$FF,(CONE1<<{1})&$FF,(CONE2<<{1})&$FF,(CONE3<<{1})&$FF
   1020  f4b7					      .byte	(CONE4<<{1})&$FF,(CONE5<<{1})&$FF,(CONE6<<{1})&$FF,(CONE7<<{1})&$FF
   1021  f4b7					      ENDM		; {1} = left-shift amount (asl); 0 = base art
   1022  f4b7					      MAC	skull_rows
