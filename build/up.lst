    112  0000 ????				      lda	#{1}
    113  0000 ????				      sta	sfxId
    114  0000 ????				      lda	#{2}
    115  0000 ????				      sta	sfxTimer
    116  0000 ????				      ENDM		; {1} = SFX id, {2} = duration in frames
