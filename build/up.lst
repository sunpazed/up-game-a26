    890  f43f							;-------------------------------------------------------------
    891  f43f							; Missile-0 cycle-74 strobe table (must stay within one page).
    892  f43f							;   Each entry strobes RESM0; the $1C (NOP abs) swallows the next
    893  f43f							;   entry's `sta RESM0`, so only the jumped-to strobe executes, then
    894  f43f							;   execution falls through to `sta HMOVE` at cycle ~74.
    895  f43f							;-------------------------------------------------------------
    896  f500					      org	$f500
    897  f500				   PosTblM0
    898  f500				   pM0_3
    899  f500		       85 12		      sta	RESM0
    900  f502		       1c		      .byte.b	$1C
    901  f503				   pM0_15
    902  f503		       85 12		      sta	RESM0
    903  f505		       1c		      .byte.b	$1C
    904  f506				   pM0_30
    905  f506		       85 12		      sta	RESM0
    906  f508		       1c		      .byte.b	$1C
    907  f509				   pM0_45
    908  f509		       85 12		      sta	RESM0
    909  f50b		       1c		      .byte.b	$1C
    910  f50c				   pM0_60
    911  f50c		       85 12		      sta	RESM0
    912  f50e		       1c		      .byte.b	$1C
    913  f50f				   pM0_75
    914  f50f		       85 12		      sta	RESM0
    915  f511		       1c		      .byte.b	$1C
    916  f512				   pM0_90
    917  f512		       85 12		      sta	RESM0
    918  f514		       1c		      .byte.b	$1C
    919  f515				   pM0_105
    920  f515		       85 12		      sta	RESM0
    921  f517		       1c		      .byte.b	$1C
    922  f518				   pM0_120
    923  f518		       85 12		      sta	RESM0
    924  f51a		       1c		      .byte.b	$1C
    925  f51b				   pM0_135
    926  f51b		       85 12		      sta	RESM0
    927  f51d		       1c		      .byte.b	$1C
    928  f51e				   pM0_150
    929  f51e		       85 12		      sta	RESM0
    930  f520		       85 2a		      sta	HMOVE
    931  f522		       85 02		      sta	WSYNC	; re-align: the positioning line ends here so the
    932  f524		       60		      rts		; band keeps an exact, identical scanline budget
    933  f525
    934  f525				   JumpTabM0
    935  f525		       00 03 06 09*	      .byte.b	<pM0_3, <pM0_15, <pM0_30, <pM0_45, <pM0_60, <pM0_75
    936  f52b		       12 15 18 1b*	      .byte.b	<pM0_90, <pM0_105, <pM0_120, <pM0_135, <pM0_150
