   1017  f798							;-------------------------------------------------------------
   1018  f798							; DrawDigits - render the 48x8 score from Digit0..Digit5 pointers.
   1019  f798							; Page-aligned so BigLoop's branch stays in-page (exact 76-cycle rows).
   1020  f798							; After examples/6-digit-score.asm (Temp -> tempOne, LoopCount -> loopCnt).
   1021  f798							;-------------------------------------------------------------
   1022  f800		       00 00 00 00*	      align	$100
   1023  f800				   DrawDigits
   1024  f800		       a9 07		      lda	#7
   1025  f802		       85 d4		      sta	loopCnt
   1026  f804		       85 02		      sta	WSYNC
      0  f806					      SLEEP	60
      1  f806				   .CYCLES    SET	60
      2  f806
      3  f806				  -	      IF	.CYCLES < 2
