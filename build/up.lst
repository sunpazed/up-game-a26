    732  f31b		       18		      clc
    733  f31c		       65 b0		      adc	scrollSpeed	; accumulate 1/32-px units
    734  f31e		       aa		      tax		; X = total (whole.frac)
    735  f31f		       29 1f		      and	#$1F
    736  f321		       85 b1		      sta	scrollFrac	; carry the fraction (low 5 bits) to next frame
    737  f323		       8a		      txa
    738  f324		       4a		      lsr
    739  f325		       4a		      lsr
    740  f326		       4a		      lsr
    741  f327		       4a		      lsr
