    974  f505		       1c		      .byte.b	$1C
    975  f506				   pM0_30
    976  f506		       85 12		      sta	RESM0
    977  f508		       1c		      .byte.b	$1C
    978  f509				   pM0_45
    979  f509		       85 12		      sta	RESM0
    980  f50b		       1c		      .byte.b	$1C
    981  f50c				   pM0_60
    982  f50c		       85 12		      sta	RESM0
    983  f50e		       1c		      .byte.b	$1C
    984  f50f				   pM0_75
    985  f50f		       85 12		      sta	RESM0
    986  f511		       1c		      .byte.b	$1C
    987  f512				   pM0_90
    988  f512		       85 12		      sta	RESM0
    989  f514		       1c		      .byte.b	$1C
    990  f515				   pM0_105
    991  f515		       85 12		      sta	RESM0
    992  f517		       1c		      .byte.b	$1C
    993  f518				   pM0_120
    994  f518		       85 12		      sta	RESM0
    995  f51a		       1c		      .byte.b	$1C
    996  f51b				   pM0_135
    997  f51b		       85 12		      sta	RESM0
    998  f51d		       1c		      .byte.b	$1C
    999  f51e				   pM0_150
   1000  f51e		       85 12		      sta	RESM0
   1001  f520		       85 2a		      sta	HMOVE
   1002  f522		       85 02		      sta	WSYNC	; re-align: the positioning line ends here so the
   1003  f524		       60		      rts		; band keeps an exact, identical scanline budget
