    173  f000				   Reset
      0  f000					      CLEAN_START		; zeros all RAM (hiScore starts at 0)
      1  f000		       78		      sei
      2  f001		       d8		      cld
      3  f002
      4  f002		       a2 00		      ldx	#0
      5  f004		       8a		      txa
      6  f005		       a8		      tay
      7  f006		       ca	   .CLEAR_STACK dex
      8  f007		       9a		      txs
      9  f008		       48		      pha
     10  f009		       d0 fb		      bne	.CLEAR_STACK
     11  f00b
    175  f00b
    176  f00b							; --- one-time setup (survives a soft restart) ---
    177  f00b							; Solid, full-width playfield (held for the whole program)
    178  f00b		       a9 f0		      lda	#$F0
    179  f00d		       85 0d		      sta	PF0
    180  f00f		       a9 ff		      lda	#$FF
    181  f011		       85 0e		      sta	PF1
    182  f013		       85 0f		      sta	PF2
    183  f015		       a9 00		      lda	#0
    184  f017		       85 0a		      sta	CTRLPF	; players/missiles draw over the playfield
    185  f019
    186  f019							; Missile 0 is GAP_WIDTH wide (player stays normal width)
    187  f019		       a9 30		      lda	#$30
    188  f01b		       85 04		      sta	NUSIZ0
    189  f01d
    190  f01d							; Default every motion register to $80, the cycle-74 HMOVE "no motion"
    191  f01d							; value: the per-band cycle-74 HMOVEs re-apply ALL HMxx, and $00 there
    192  f01d							; is NOT zero motion (it would walk the object); $80 (NO_MO_74) holds
    193  f01d							; non-targeted objects still. The player P0 is (re)placed each frame in
    194  f01d							; the HUD transition; gaps/entities are placed per band.
    195  f01d		       85 2b		      sta	HMCLR
    196  f01f		       a9 80		      lda	#$80
    197  f021		       85 20		      sta	HMP0
    198  f023		       85 22		      sta	HMM0
    199  f025		       85 21		      sta	HMP1
    200  f027
    201  f027		       a9 01		      lda	#1
    202  f029		       85 c1		      sta	rng	; PRNG seed (set once; advances across games)
    203  f02b
    204  f02b		       a9 00		      lda	#0
    205  f02d		       85 19		      sta	AUDV0	; silence both audio channels at boot
    206  f02f		       85 1a		      sta	AUDV1
    207  f031
    208  f031							;-------------------------------------------------------------
    209  f031							; NewGame - (re)start a round. Reached from Reset and from a game-over
    210  f031							; restart. Resets all gameplay state but NOT hiScore (or rng).
    211  f031							;-------------------------------------------------------------
    212  f031				   NewGame
    213  f031		       a9 0e		      lda	#COL_BG
    214  f033		       85 09		      sta	COLUBK	; clear any game-over red tint
    215  f035
    216  f035		       a9 05		      lda	#5
    217  f037		       85 80		      sta	playerFloor	; player starts on the bottom tier
    218  f039		       a9 9d		      lda	#5*30+PREST_OFF	; visual Y settled on floor 5 (157)
    219  f03b		       85 82		      sta	playerY
    220  f03d		       a9 00		      lda	#0
    221  f03f		       85 83		      sta	btnPrev
    222  f041		       85 c5		      sta	gameState
    223  f043		       85 cb		      sta	goCnt
    224  f045		       85 c4		      sta	sfxTimer	; stop any leftover sound (e.g. the death sting)
    225  f047		       85 c6		      sta	scoreBCD+0
    226  f049		       85 c7		      sta	scoreBCD+1
    227  f04b		       85 c8		      sta	scoreBCD+2
    228  f04d		       85 b1		      sta	scrollFrac
    229  f04f		       85 cc		      sta	animFrame	; start on run-cycle frame 0
    230  f051		       a9 16		      lda	#ANIM_BASE
    231  f053		       85 cd		      sta	animTimer
    232  f055		       a9 20		      lda	#SPEED_BASE
    233  f057		       85 b0		      sta	scrollSpeed	; start each game at base speed (1 px/frame)
    234  f059
    235  f059							; (gap layout is randomised below, after the PRNG is reseeded)
    236  f059
    237  f059							; Reseed the PRNG from the free-running frame counter (mixed with whatever
    238  f059							; state carried over), so each restart differs -- the human-variable delay
    239  f059							; before pressing fire makes frameCnt effectively random. Keep it non-zero
    240  f059							; (an all-zero LFSR is a dead state).
    241  f059		       a5 c1		      lda	rng
    242  f05b		       45 c2		      eor	frameCnt
    243  f05d		       d0 02		      bne	.seedOk
    244  f05f		       a9 01		      lda	#1
    245  f061				   .seedOk
    246  f061		       85 c1		      sta	rng
    247  f063
    248  f063							; Randomise the gap (slot) layout per game. Each floor gets a fully random x;
    249  f063							; re-roll any that lands within GAP_MIN_SEP of the floor below so holes never
    250  f063							; stack (which would drop the player straight through) -- but the result is
    251  f063							; non-monotonic (no rigid diagonal). Candidates stay in 16..143 (away from the
    252  f063							; 0/159 wrap zone, so the same separation holds as they scroll). Floor 5: none.
    253  f063		       a2 04		      ldx	#4
    254  f065				   .ngGapFloor
    255  f065		       a0 08		      ldy	#8	; re-roll attempt cap (collisions are rare)
    256  f067				   .ngGapRoll
    257  f067		       20 97 f2 	      jsr	Rng	; (Rng preserves X and Y)
    258  f06a		       29 7f		      and	#$7F
    259  f06c		       18		      clc
    260  f06d		       69 10		      adc	#16	; candidate 16..143
    261  f06f		       85 86		      sta	tempOne
    262  f071		       e0 04		      cpx	#4
    263  f073		       f0 11		      beq	.ngGapOk	; first floor placed: nothing below to clash with
    264  f075		       38		      sec
    265  f076		       f5 8d		      sbc	gapX+1,x	; A = candidate - gap on the floor below
    266  f078		       b0 05		      bcs	.ngGapAbs
    267  f07a		       49 ff		      eor	#$FF
    268  f07c		       18		      clc
    269  f07d		       69 01		      adc	#1	; A = |difference|
    270  f07f				   .ngGapAbs
    271  f07f		       c9 18		      cmp	#GAP_MIN_SEP
    272  f081		       b0 03		      bcs	.ngGapOk	; far enough from the floor below -> accept
    273  f083		       88		      dey
    274  f084		       d0 e1		      bne	.ngGapRoll	; too close -> re-roll (capped)
    275  f086				   .ngGapOk
    276  f086		       a5 86		      lda	tempOne
    277  f088		       95 8c		      sta	gapX,x
    278  f08a		       ca		      dex
    279  f08b		       10 d8		      bpl	.ngGapFloor
    280  f08d		       a9 00		      lda	#0
    281  f08f		       85 91		      sta	gapX+5
    282  f091
    283  f091							; Start with EMPTY platforms: every entity begins hidden and slides in from
    284  f091							; the right edge (via the normal respawn path, which rolls a random type and
    285  f091							; clears gaps). Each gets a RANDOM first-spawn delay so they don't all enter
    286  f091							; evenly spaced (which read as a rigid diagonal). entX is set on spawn.
    287  f091		       a2 05		      ldx	#5
    288  f093				   .ngEnt
    289  f093		       a9 00		      lda	#0
    290  f095		       95 9e		      sta	entType,x	; hidden -> .entWaiting spawns it (slide-in)
    291  f097		       95 ce		      sta	entSlide,x
    292  f099		       95 da		      sta	entRefp,x
    293  f09b		       a9 30		      lda	#<ZeroSprite
    294  f09d		       95 d4		      sta	entDrawLo,x
    295  f09f		       20 97 f2 	      jsr	Rng	; random first-spawn delay (Rng preserves X)
    296  f0a2		       29 3f		      and	#$3F
    297  f0a4		       18		      clc
    298  f0a5		       69 08		      adc	#8	; 8..71 frames -> entities enter at varied times
    299  f0a7		       95 aa		      sta	entDelay,x
    300  f0a9		       ca		      dex
    301  f0aa		       10 e7		      bpl	.ngEnt
    302  f0ac
    303  f0ac		       20 5a f8 	      jsr	GetDigitPtrs	; seed digit pointers for the first HUD
    304  f0af
    305  f0af							;-------------------------------------------------------------
    306  f0af							; Main frame loop
    307  f0af							;-------------------------------------------------------------
    308  f0af				   NextFrame
    309  f0af		       a9 02		      lda	#2
    310  f0b1		       85 01		      sta	VBLANK
      0  f0b3					      VERTICAL_SYNC		; 3 vsync lines (leaves A=0)
      1  f0b3		       a9 0e		      lda	#%1110
      2  f0b5		       85 02	   .VSLP1     sta	WSYNC
      3  f0b7		       85 00		      sta	VSYNC
      4  f0b9		       4a		      lsr
      5  f0ba		       d0 f9		      bne	.VSLP1
    312  f0bc		       85 2c		      sta	CXCLR	; clear collision latches for this frame
    313  f0be
    314  f0be							; --- position the score sprites (P0+P1, 3 copies each = 6 digits) ---
    315  f0be							; (uses 2 of the 36 VBLANK scanlines; the rest are the WSYNC loop below)
    316  f0be		       a9 03		      lda	#THREE_COPIES
    317  f0c0		       85 04		      sta	NUSIZ0
    318  f0c2		       85 05		      sta	NUSIZ1
    319  f0c4		       a9 00		      lda	#SCORE_COL
    320  f0c6		       85 06		      sta	COLUP0
    321  f0c8		       85 07		      sta	COLUP1
    322  f0ca		       85 02		      sta	WSYNC	; vblank line 1
      0  f0cc					      SLEEP	SCORE_SLEEP
      1  f0cc				   .CYCLES    SET	SCORE_SLEEP
      2  f0cc
      3  f0cc				  -	      IF	.CYCLES < 2
      4  f0cc				  -	      ECHO	"MACRO ERROR: 'SLEEP': Duration must be > 1"
      5  f0cc				  -	      ERR
      6  f0cc					      ENDIF
      7  f0cc
      8  f0cc				  -	      IF	.CYCLES & 1
      9  f0cc				  -	      IFNCONST	NO_ILLEGAL_OPCODES
     10  f0cc				  -	      nop	0
     11  f0cc				  -	      ELSE
     12  f0cc				  -	      bit	VSYNC
     13  f0cc				  -	      ENDIF
     14  f0cc				  -.CYCLES    SET	.CYCLES - 3
     15  f0cc					      ENDIF
     16  f0cc
     17  f0cc					      REPEAT	.CYCLES / 2
     18  f0cc		       ea		      nop
