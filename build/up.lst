    800  f3b5							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
    801  f3b5							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
    802  f3b5							;   (After examples/6-digit-score.asm.)
