    782  f387		       a9 98		      lda	#ENT_WRAP
    783  f389		       95 a3		      sta	entX,x
    784  f38b		       a9 87		      lda	#$80|7	; begin sliding IN from the right edge (reflected)
    785  f38d		       95 cd		      sta	entSlide,x
    786  f38f				   .entNext
    787  f38f		       ca		      dex
    788  f390		       10 86		      bpl	.entLoop
