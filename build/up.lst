     94 U0080		       00	   playerFloor ds	1	; 0 = top tier .. 5 = bottom tier
     95 U0081		       00	   playerBandCount ds	1	; bandCount value at which to draw the player
     96 U0082		       00	   btnPrev    ds	1	; fire button state last frame (edge detect)
     97 U0083		       00	   bandCount  ds	1	; bands remaining in the visible kernel
     98 U0084		       00	   curFloor   ds	1	; floor index of the band being drawn
     99 U0085		       00	   tempOne    ds	1	; scratch for the fast divide in CalcQuickPos
    100 U0086		       00	   tempFloor  ds	1	; scratch floor index across CalcQuickPos
    101 U0087		       00 00	   sprPtr     ds	2	; pointer to current band's sprite data
    102 U0089		       00 00	   posJmp     ds	2	; indirect pointer into the missile strobe table
    103 U008b		       00 00 00 00*gapX       ds	6	; per-floor gap x position (floor 5 unused/no gap)
    104 U0091		       00 00 00 00*gapQuick   ds	6	; per-floor precomputed quickPos (HMM0 fine | delay count)
    105 U0097		       00 00 00 00*posJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    106 U009d		       00 00 00 00*entType    ds	6	; per-floor entity: 0 none/hidden, 1 cone, 2 skull
    107 U00a3		       00 00 00 00*entX       ds	6	; per-floor entity x position
    108 U00a9		       00 00 00 00*entDelay   ds	6	; per-floor frames left to wait off-screen before respawn
    109 U00af		       00	   scrollSpeed ds	1	; fractional scroll speed (ramps with score)
    110 U00b0		       00	   scrollFrac ds	1	; fixed-point fractional accumulator
    111 U00b1		       00	   scrollStep ds	1	; whole pixels to scroll this frame
    112 U00b2		       00 00 00 00*entQuick   ds	6	; per-floor precomputed quickPos for the entity (GRP1)
    113 U00b8		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    114 U00be		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    115 U00c0		       00	   rng	      ds	1	; PRNG state (LFSR)
    116 U00c1		       00	   gameState  ds	1	; 0 = playing, 1 = game over
    117 U00c2		       00 00 00    scoreBCD   ds	3	; BCD score (low 4 digits shown)
    118 U00c5		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    119 U00c7		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    120 U00c8		       00 00 00 00*Digit0     ds	12	; 6 font pointers (Digit0..Digit5) for the score kernel
    121 U00d4		       00	   loopCnt    ds	1	; scanline counter inside DrawDigits
