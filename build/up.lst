    740  f36e		       a5 c3		      lda	scoreBCD+1
    741  f370		       c5 c6		      cmp	hiScore+1
    742  f372		       90 10		      bcc	.ccDone	; score's high pair < hiScore's
    743  f374		       d0 06		      bne	.ccNewHi	; score's high pair > hiScore's
    744  f376		       a5 c2		      lda	scoreBCD+0
    745  f378		       c5 c5		      cmp	hiScore+0
