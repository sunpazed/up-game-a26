    701  f309							; UpdateWorld - scroll gaps left, wrap, and fall-through check
    702  f309							;-------------------------------------------------------------
    703  f309				   UpdateWorld
    704  f309							; advance the PRNG once per frame so respawns stay varied
    705  f309		       20 c9 f2 	      jsr	Rng
    706  f30c
    707  f30c							; Sub-pixel speed: accumulate the fractional speed; the carry is an
    708  f30c							; extra whole pixel this frame, so the scroll step is 1 or 2 px.
    709  f30c							; (scrollSpeed ramps with the score; see CheckCollision.)
    710  f30c		       a5 b0		      lda	scrollFrac
    711  f30e		       18		      clc
    712  f30f		       65 af		      adc	scrollSpeed	; accumulate 1/32-px units
    713  f311		       aa		      tax		; X = total (whole.frac)
    714  f312		       29 1f		      and	#$1F
    715  f314		       85 b0		      sta	scrollFrac	; carry the fraction (low 5 bits) to next frame
    716  f316		       8a		      txa
    717  f317		       4a		      lsr
    718  f318		       4a		      lsr
    719  f319		       4a		      lsr
    720  f31a		       4a		      lsr
    721  f31b		       4a		      lsr		; whole pixels this frame = total >> 5
    722  f31c		       85 b1		      sta	scrollStep
    723  f31e
    724  f31e							; Everything below advances by scrollStep in ONE pass (O(1)) rather than a
    725  f31e							; per-pixel loop, so the overscan cost stays flat as the speed ramps -- the
    726  f31e							; per-pixel loop was up to 4x work at top speed and overran the overscan
    727  f31e							; timer (causing the screen to roll, worst on the heavier cone-pickup frame).
    728  f31e
    729  f31e							; --- scroll gaps (floors 0..4): gapX -= step, wrap <=0 back to GAP_WRAP ---
    730  f31e		       a2 04		      ldx	#4
    731  f320				   .gapLoop
    732  f320		       b5 8b		      lda	gapX,x
    733  f322		       38		      sec
    734  f323		       e5 b1		      sbc	scrollStep
    735  f325		       90 02		      bcc	.gapWrap	; underflowed past 0 -> wrap in from the right edge
    736  f327		       d0 03		      bne	.gapStore	; still > 0
    737  f329				   .gapWrap		; A is 0 or the negative remainder; +GAP_WRAP re-enters
    738  f329		       18		      clc
    739  f32a		       69 9f		      adc	#GAP_WRAP
    740  f32c				   .gapStore
    741  f32c		       95 8b		      sta	gapX,x
    742  f32e		       ca		      dex
    743  f32f		       10 ef		      bpl	.gapLoop
