   1351  f8da							;-------------------------------------------------------------
   1352  f8da							; UpdateSound - advance the one-shot SFX on channel 0 (called every frame in
   1353  f8da							;   all game states, so the death sound keeps playing through the freeze).
   1354  f8da							;   sfxTimer counts down; AUDC0/AUDF0/AUDV0 are derived from the id + timer.
   1355  f8da							;-------------------------------------------------------------
   1356  f8da				   UpdateSound
   1357  f8da		       a5 c4		      lda	sfxTimer
   1358  f8dc		       d0 01		      bne	.usPlay
   1359  f8de		       60		      rts		; idle (already silent)
   1360  f8df				   .usPlay
   1361  f8df		       c6 c4		      dec	sfxTimer
   1362  f8e1		       f0 11		      beq	.usSilence	; last frame elapsed -> turn the channel off
   1363  f8e3		       a5 c3		      lda	sfxId
   1364  f8e5		       c9 01		      cmp	#SFX_JUMP
   1365  f8e7		       f0 10		      beq	.usJump
   1366  f8e9		       c9 02		      cmp	#SFX_DROP
   1367  f8eb		       f0 1c		      beq	.usDrop
   1368  f8ed		       c9 03		      cmp	#SFX_CONE
   1369  f8ef		       f0 28		      beq	.usCone
   1370  f8f1		       4c 31 f9 	      jmp	.usDeath
   1371  f8f4				   .usSilence
   1372  f8f4		       a9 00		      lda	#0
   1373  f8f6		       85 19		      sta	AUDV0
   1374  f8f8		       60		      rts
   1375  f8f9
   1376  f8f9				   .usJump		; pure tone, pitch RISES (AUDF falls as timer falls)
   1377  f8f9		       a9 04		      lda	#SFX_TONE
   1378  f8fb		       85 15		      sta	AUDC0
   1379  f8fd		       a5 c4		      lda	sfxTimer
   1380  f8ff		       18		      clc
   1381  f900		       69 03		      adc	#3
   1382  f902		       85 17		      sta	AUDF0
   1383  f904		       a9 0a		      lda	#SFX_VOL
   1384  f906		       85 19		      sta	AUDV0
   1385  f908		       60		      rts
   1386  f909
   1387  f909				   .usDrop		; pure tone, pitch FALLS (AUDF rises as timer falls)
   1388  f909		       a9 04		      lda	#SFX_TONE
   1389  f90b		       85 15		      sta	AUDC0
   1390  f90d		       a9 0c		      lda	#DROP_DUR
   1391  f90f		       38		      sec
   1392  f910		       e5 c4		      sbc	sfxTimer
   1393  f912		       85 17		      sta	AUDF0
   1394  f914		       a9 0a		      lda	#SFX_VOL
   1395  f916		       85 19		      sta	AUDV0
   1396  f918		       60		      rts
   1397  f919
   1398  f919				   .usCone		; two-note coin: low note then a higher one
   1399  f919		       a9 04		      lda	#SFX_TONE
   1400  f91b		       85 15		      sta	AUDC0
   1401  f91d		       a9 0a		      lda	#SFX_VOL
   1402  f91f		       85 19		      sta	AUDV0
   1403  f921		       a5 c4		      lda	sfxTimer
   1404  f923		       c9 08		      cmp	#CONE_DUR/2
   1405  f925		       b0 05		      bcs	.usConeLo	; first half -> low note
   1406  f927		       a9 07		      lda	#7	; second half -> higher note (lower AUDF)
   1407  f929		       85 17		      sta	AUDF0
   1408  f92b		       60		      rts
   1409  f92c				   .usConeLo
   1410  f92c		       a9 0d		      lda	#13
   1411  f92e		       85 17		      sta	AUDF0
   1412  f930		       60		      rts
   1413  f931
   1414  f931				   .usDeath		; white noise: "tah" burst, gap, "tish" burst
   1415  f931		       a9 08		      lda	#SFX_NOISE
   1416  f933		       85 15		      sta	AUDC0
   1417  f935		       a5 c4		      lda	sfxTimer
   1418  f937		       c9 0d		      cmp	#13
   1419  f939		       b0 09		      bcs	.usDeathTah	; 13.. -> first (lower) burst
   1420  f93b		       c9 0a		      cmp	#10
   1421  f93d		       90 0e		      bcc	.usDeathTish	; ..9	-> second (sharper) burst
   1422  f93f		       a9 00		      lda	#0	; 10..12 -> short gap
   1423  f941		       85 19		      sta	AUDV0
