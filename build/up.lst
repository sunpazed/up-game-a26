    754  f32f		       38		      sec
    755  f330		       e5 b2		      sbc	scrollStep
    756  f332		       90 02		      bcc	.gapWrap	; underflowed past 0 -> wrap in from the right edge
    757  f334		       d0 03		      bne	.gapStore	; still > 0
    758  f336				   .gapWrap		; A is 0 or the negative remainder; +GAP_WRAP re-enters
    759  f336		       18		      clc
    760  f337		       69 9f		      adc	#GAP_WRAP
    761  f339				   .gapStore
    762  f339		       95 8c		      sta	gapX,x
