    130 U0086		       00	   tempFloor  ds	1	; scratch floor index across CalcQuickPos
    131 U0087		       00 00	   sprPtr     ds	2	; pointer to current band's sprite data
    132 U0089		       00 00	   posJmp     ds	2	; indirect pointer into the missile strobe table
    133 U008b		       00 00 00 00*gapX       ds	6	; per-floor gap x position (floor 5 unused/no gap)
    134 U0091		       00 00 00 00*gapQuick   ds	6	; per-floor precomputed quickPos (HMM0 fine | delay count)
    135 U0097		       00 00 00 00*posJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
