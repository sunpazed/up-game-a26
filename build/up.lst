    123 U00ed ????				      SEG.U	vars
    124 U0080					      org	$80
    125 U0080
    126 U0080		       00	   playerFloor ds	1	; 0 = top tier .. 5 = bottom tier (logical, instant)
    127 U0081		       00	   playerBandCount ds	1	; bandCount value at which to draw the player
    128 U0082		       00	   playerY    ds	1	; visual top scanline of the player (band-region rel.);
    129 U0083							;   lerps toward restY = playerFloor*30+7 (jump/fall glide)
    130 U0083		       00	   btnPrev    ds	1	; fire button state last frame (edge detect)
    131 U0084		       00	   bandCount  ds	1	; bands remaining in the visible kernel
    132 U0085		       00	   curFloor   ds	1	; floor index of the band being drawn
    133 U0086		       00	   tempOne    ds	1	; scratch for the fast divide in CalcQuickPos
    134 U0087		       00	   tempFloor  ds	1	; scratch floor index across CalcQuickPos
    135 U0088		       00 00	   sprPtr     ds	2	; pointer to current band's sprite data
    136 U008a		       00 00	   posJmp     ds	2	; indirect pointer into the missile strobe table
    137 U008c		       00 00 00 00*gapX       ds	6	; per-floor gap x position (floor 5 unused/no gap)
    138 U0092		       00 00 00 00*gapQuick   ds	6	; per-floor precomputed quickPos (HMM0 fine | delay count)
    139 U0098		       00 00 00 00*posJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    140 U009e		       00 00 00 00*entType    ds	6	; per-floor entity: 0 none/hidden, 1 cone, 2 skull
    141 U00a4		       00 00 00 00*entX       ds	6	; per-floor entity x position
    142 U00aa		       00 00 00 00*entDelay   ds	6	; per-floor frames left to wait off-screen before respawn
    143 U00b0		       00	   scrollSpeed ds	1	; fractional scroll speed (ramps with score)
    144 U00b1		       00	   scrollFrac ds	1	; fixed-point fractional accumulator
    145 U00b2		       00	   scrollStep ds	1	; whole pixels to scroll this frame
    146 U00b3		       00 00 00 00*entQuick   ds	6	; per-floor precomputed quickPos for the entity (GRP1)
    147 U00b9		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    148 U00bf		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    149 U00c1		       00	   rng	      ds	1	; PRNG state (LFSR)
    150 U00c2		       00	   frameCnt   ds	1	; free-running frame counter (never reset; RNG reseed)
    151 U00c3		       00	   sfxId      ds	1	; sound effect currently playing (0 = none)
    152 U00c4		       00	   sfxTimer   ds	1	; frames left in the current sound effect
    153 U00c5		       00	   gameState  ds	1	; 0 = playing, 1 = game over
    154 U00c6		       00 00 00    scoreBCD   ds	3	; BCD score (low 4 digits shown)
    155 U00c9		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    156 U00cb		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    157 U00cc		       00	   animFrame  ds	1	; player run-cycle frame (0 or 1)
    158 U00cd		       00	   animTimer  ds	1	; frames left until the next player-frame swap
    159 U00ce		       00 00 00 00*entSlide   ds	6	; per-floor edge-slide state: 0 = normal; 1..7 = sliding
    160 U00d4							;   OUT the LEFT edge (asl amount); $80|N = sliding IN
    161 U00d4							;   the RIGHT edge (asl amount N, reflected via REFP1)
    162 U00d4		       00 00 00 00*entDrawLo  ds	6	; per-floor resolved entity sprite low byte (base or shift)
    163 U00da		       00 00 00 00*entRefp    ds	6	; per-floor REFP1 value ($08 while sliding in, else $00)
    164 U00e0		       00 00 00 00*Digit0     ds	12	; 6 font pointers (Digit0..Digit5) for the score kernel
    165 U00ec		       00	   loopCnt    ds	1	; scanline counter inside DrawDigits
