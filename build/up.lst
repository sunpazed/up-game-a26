    797  f3c7		       85 c8		      sta	Digit0+0
    798  f3c9		       a9 90		      lda	#<LetterI
    799  f3cb		       85 ca		      sta	Digit0+2
    800  f3cd		       a2 04		      ldx	#4
    801  f3cf		       a0 01		      ldy	#1
    802  f3d1				   .goHiLoop
    803  f3d1		       b9 c5 00 	      lda	hiScore,y
    804  f3d4		       29 f0		      and	#$f0
    805  f3d6		       4a		      lsr
    806  f3d7		       95 c8		      sta	Digit0,x
    807  f3d9		       e8		      inx
    808  f3da		       e8		      inx
    809  f3db		       b9 c5 00 	      lda	hiScore,y
    810  f3de		       29 0f		      and	#$0f
    811  f3e0		       0a		      asl
    812  f3e1		       0a		      asl
    813  f3e2		       0a		      asl
    814  f3e3		       95 c8		      sta	Digit0,x
