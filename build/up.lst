    659  f2df		       a5 af		      lda	scrollSpeed
    660  f2e1		       4a		      lsr
    661  f2e2		       4a		      lsr
    662  f2e3		       4a		      lsr		; scrollSpeed >> 3
    663  f2e4		       85 cc		      sta	animTimer	; (temp)
