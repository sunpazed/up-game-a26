    833  f3cf							; leftmost (most-significant) digits, so the +1 must land on the
    834  f3cf							; least-significant byte scoreBCD+0 and carry up toward +2.
    835  f3cf		       f8		      sed
    836  f3d0		       a5 c5		      lda	scoreBCD+0
    837  f3d2		       18		      clc
    838  f3d3		       69 01		      adc	#1
