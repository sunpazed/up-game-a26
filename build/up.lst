   1222  f798							; DrawDigits - render the 48x8 score from Digit0..Digit5 pointers.
   1223  f798							; Page-aligned so BigLoop's branch stays in-page (exact 76-cycle rows).
   1224  f798							; After examples/6-digit-score.asm (Temp -> tempOne, LoopCount -> loopCnt).
   1225  f798							;-------------------------------------------------------------
   1226  f800		       00 00 00 00*	      align	$100
   1227  f800				   DrawDigits
   1228  f800		       a9 07		      lda	#7
   1229  f802		       85 ec		      sta	loopCnt
   1230  f804		       85 02		      sta	WSYNC
      0  f806					      SLEEP	60
      1  f806				   .CYCLES    SET	60
      2  f806
      3  f806				  -	      IF	.CYCLES < 2
      4  f806				  -	      ECHO	"MACRO ERROR: 'SLEEP': Duration must be > 1"
      5  f806				  -	      ERR
      6  f806					      ENDIF
      7  f806
      8  f806				  -	      IF	.CYCLES & 1
      9  f806				  -	      IFNCONST	NO_ILLEGAL_OPCODES
     10  f806				  -	      nop	0
     11  f806				  -	      ELSE
     12  f806				  -	      bit	VSYNC
     13  f806				  -	      ENDIF
     14  f806				  -.CYCLES    SET	.CYCLES - 3
     15  f806					      ENDIF
     16  f806
     17  f806					      REPEAT	.CYCLES / 2
