    601  f2c6		       90 02		      bcc	.rngNoFb
    602  f2c8		       49 b4		      eor	#$B4
    603  f2ca				   .rngNoFb
    604  f2ca		       85 c0		      sta	rng
    605  f2cc		       60		      rts
    606  f2cd
    607  f2cd							;-------------------------------------------------------------
    608  f2cd							; ReadInput - one-button jump-up (rising edge of fire button)
    609  f2cd							;-------------------------------------------------------------
    610  f2cd				   ReadInput
    611  f2cd		       a2 00		      ldx	#0	; assume not pressed
    612  f2cf		       a5 0c		      lda	INPT4
    613  f2d1		       30 0c		      bmi	.store	; bit7 set => not pressed
    614  f2d3		       a2 01		      ldx	#1	; pressed
    615  f2d5		       a5 82		      lda	btnPrev
    616  f2d7		       d0 06		      bne	.store	; held => no new press
    617  f2d9		       a5 80		      lda	playerFloor
    618  f2db		       f0 02		      beq	.store	; already at top tier
    619  f2dd		       c6 80		      dec	playerFloor	; jump up one tier
    620  f2df				   .store
    621  f2df		       86 82		      stx	btnPrev
    622  f2e1		       60		      rts
    623  f2e2
    624  f2e2							;-------------------------------------------------------------
    625  f2e2							; AnimatePlayer - tick the run-cycle frame. Swaps frame every animTimer
    626  f2e2							;   frames; the interval shortens with scroll speed so the player's legs
    627  f2e2							;   move faster as the world speeds up.
    628  f2e2							;   interval = ANIM_BASE - (scrollSpeed >> 3)
    629  f2e2							;-------------------------------------------------------------
    630  f2e2				   AnimatePlayer
    631  f2e2		       c6 c9		      dec	animTimer
    632  f2e4		       d0 14		      bne	.apDone
    633  f2e6		       a5 c8		      lda	animFrame
    634  f2e8		       49 01		      eor	#1
    635  f2ea		       85 c8		      sta	animFrame	; toggle 0 <-> 1
    636  f2ec		       a5 af		      lda	scrollSpeed
    637  f2ee		       4a		      lsr
    638  f2ef		       4a		      lsr
    639  f2f0		       4a		      lsr		; scrollSpeed >> 3
    640  f2f1		       85 c9		      sta	animTimer	; (temp)
    641  f2f3		       a9 16		      lda	#ANIM_BASE
    642  f2f5		       38		      sec
    643  f2f6		       e5 c9		      sbc	animTimer
    644  f2f8		       85 c9		      sta	animTimer	; reload shortened interval
    645  f2fa				   .apDone
    646  f2fa		       60		      rts
    647  f2fb
    648  f2fb							;-------------------------------------------------------------
    649  f2fb							; UpdateWorld - scroll gaps left, wrap, and fall-through check
    650  f2fb							;-------------------------------------------------------------
    651  f2fb				   UpdateWorld
    652  f2fb							; advance the PRNG once per frame so respawns stay varied
    653  f2fb		       20 c3 f2 	      jsr	Rng
    654  f2fe
    655  f2fe							; Sub-pixel speed: accumulate the fractional speed; the carry is an
    656  f2fe							; extra whole pixel this frame, so the scroll step is 1 or 2 px.
    657  f2fe							; (scrollSpeed ramps with the score; see CheckCollision.)
    658  f2fe		       a5 b0		      lda	scrollFrac
    659  f300		       18		      clc
    660  f301		       65 af		      adc	scrollSpeed	; accumulate 1/32-px units
    661  f303		       aa		      tax		; X = total (whole.frac)
    662  f304		       29 1f		      and	#$1F
    663  f306		       85 b0		      sta	scrollFrac	; carry the fraction (low 5 bits) to next frame
    664  f308		       8a		      txa
    665  f309		       4a		      lsr
    666  f30a		       4a		      lsr
    667  f30b		       4a		      lsr
    668  f30c		       4a		      lsr
    669  f30d		       4a		      lsr		; whole pixels this frame = total >> 5
    670  f30e		       85 b1		      sta	scrollStep
    671  f310
    672  f310				   .scrollStep
    673  f310							; --- scroll gaps (floors 0..4 ; floor 5 has none) ---
    674  f310		       a2 04		      ldx	#4
    675  f312				   .gapLoop
    676  f312		       d6 8b		      dec	gapX,x
    677  f314		       d0 04		      bne	.gapNext	; reached 0 => wrap to the right
    678  f316		       a9 9f		      lda	#GAP_WRAP
    679  f318		       95 8b		      sta	gapX,x
    680  f31a				   .gapNext
    681  f31a		       ca		      dex
    682  f31b		       10 f5		      bpl	.gapLoop
    683  f31d
    684  f31d							; --- entities: scroll, hide for a random delay, re-enter ---
    685  f31d		       a2 05		      ldx	#5
    686  f31f				   .entLoop
    687  f31f		       b5 9d		      lda	entType,x
    688  f321		       f0 37		      beq	.entWaiting	; type 0 = hidden, waiting to respawn
    689  f323		       b5 ca		      lda	entSlide,x
    690  f325		       f0 25		      beq	.entScroll	; 0 -> normal scroll
    691  f327		       30 14		      bmi	.entSlideIn	; $80|N -> sliding IN from the right edge
    692  f329							; 1..7 -> sliding OUT the left edge (shift grows, then hide)
    693  f329		       f6 ca		      inc	entSlide,x	; advance the shift (per scroll step => speed-linked)
    694  f32b		       b5 ca		      lda	entSlide,x
    695  f32d		       c9 08		      cmp	#8
    696  f32f		       90 4d		      bcc	.entNext	; 1..7 still partly on-screen
    697  f331		       a9 00		      lda	#0
    698  f333		       95 9d		      sta	entType,x	; fully off the left edge -> hide + arm respawn
    699  f335		       95 ca		      sta	entSlide,x
    700  f337		       20 99 f3 	      jsr	SetRespawnDelay
    701  f33a		       4c 7e f3 	      jmp	.entNext
    702  f33d				   .entSlideIn
    703  f33d		       d6 ca		      dec	entSlide,x	; $80|N -> $80|(N-1): grow in from the right edge
    704  f33f		       b5 ca		      lda	entSlide,x
    705  f341		       c9 80		      cmp	#$80
    706  f343		       d0 39		      bne	.entNext	; still entering ($80|7 .. $80|1)
    707  f345		       a9 00		      lda	#0
    708  f347		       95 ca		      sta	entSlide,x	; N=0 -> fully in; normal scroll begins next step
    709  f349		       4c 7e f3 	      jmp	.entNext
    710  f34c				   .entScroll
    711  f34c							; normal scroll until the entity reaches the left edge (entX = 0)
    712  f34c		       b5 a3		      lda	entX,x
    713  f34e		       f0 05		      beq	.entStartSlide
    714  f350		       d6 a3		      dec	entX,x
    715  f352		       4c 7e f3 	      jmp	.entNext
    716  f355				   .entStartSlide
    717  f355		       f6 ca		      inc	entSlide,x	; 0 -> 1: hold at x=0, kernel now draws asl x1
    718  f357		       4c 7e f3 	      jmp	.entNext
    719  f35a				   .entWaiting
    720  f35a		       d6 a9		      dec	entDelay,x
    721  f35c		       d0 20		      bne	.entNext
    722  f35e							; delay elapsed -> respawn, but not over this floor's gap. If the gap
    723  f35e							; is in the spawn zone, wait a little and recheck (they scroll at the
    724  f35e							; same speed, so clearing them at spawn keeps them apart all pass).
    725  f35e		       b5 8b		      lda	gapX,x
    726  f360		       c9 91		      cmp	#GAP_SPAWN_CLEAR
    727  f362		       90 07		      bcc	.doSpawn
    728  f364		       a9 10		      lda	#ENT_DEFER
    729  f366		       95 a9		      sta	entDelay,x
    730  f368		       4c 7e f3 	      jmp	.entNext
    731  f36b				   .doSpawn
    732  f36b		       20 c3 f2 	      jsr	Rng
    733  f36e		       29 03		      and	#3
    734  f370		       a8		      tay
    735  f371		       b9 e0 f4 	      lda	EntTypeRoll,y
    736  f374		       95 9d		      sta	entType,x
    737  f376		       a9 98		      lda	#ENT_WRAP
    738  f378		       95 a3		      sta	entX,x
    739  f37a		       a9 87		      lda	#$80|7	; begin sliding IN from the right edge (reflected)
    740  f37c		       95 ca		      sta	entSlide,x
    741  f37e				   .entNext
    742  f37e		       ca		      dex
    743  f37f		       10 9e		      bpl	.entLoop
    744  f381
    745  f381		       c6 b1		      dec	scrollStep
    746  f383		       d0 8b		      bne	.scrollStep	; run the scroll 1 or 2 times this frame
    747  f385
    748  f385							; --- fall-through (once per frame): gap under the player? ---
    749  f385		       a5 80		      lda	playerFloor
    750  f387		       c9 05		      cmp	#5
    751  f389		       b0 0d		      bcs	.noFall	; bottom tier is solid/safe
    752  f38b		       aa		      tax
    753  f38c		       b5 8b		      lda	gapX,x
    754  f38e		       c9 13		      cmp	#FALL_HI+1
    755  f390		       b0 06		      bcs	.noFall	; gap is right of the player
    756  f392		       c9 0e		      cmp	#FALL_LO
    757  f394		       90 02		      bcc	.noFall	; gap is left of the player
    758  f396		       e6 80		      inc	playerFloor	; fall down one tier
    759  f398				   .noFall
    760  f398		       60		      rts
