   1188  f832		       b1 e3		      lda	(Digit0+4),y
   1189  f834		       85 1b		      sta	GRP0
   1190  f836		       b1 e9		      lda	(Digit0+10),y
   1191  f838		       85 85		      sta	tempOne
   1192  f83a		       b1 e7		      lda	(Digit0+8),y
   1193  f83c		       aa		      tax
   1194  f83d		       b1 e5		      lda	(Digit0+6),y
   1195  f83f		       a4 85		      ldy	tempOne
   1196  f841		       85 1c		      sta	GRP1
   1197  f843		       86 1b		      stx	GRP0
   1198  f845		       84 1c		      sty	GRP1
   1199  f847		       85 1b		      sta	GRP0
   1200  f849		       c6 eb		      dec	loopCnt
   1201  f84b		       10 d7		      bpl	.bigLoop
   1202  f84d		       a9 00		      lda	#0
   1203  f84f		       85 1b		      sta	GRP0
   1204  f851		       85 1c		      sta	GRP1
   1205  f853		       85 1b		      sta	GRP0
   1206  f855		       85 1c		      sta	GRP1
   1207  f857		       85 02		      sta	WSYNC	; align: DrawDigits is exactly 9 scanlines
   1208  f859		       60		      rts
