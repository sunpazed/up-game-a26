    963  f47c							; AND the left/right slide shift tables (all in page f5, below) generate from the
    964  f47c							; SAME source and never drift. Edit these rows to change the cone / skull art.
    965  f47c		       00 00	   CONE0      =	%00000000
    966  f47c		       00 00	   CONE1      =	%00000000
    967  f47c		       00 ff	   CONE2      =	%11111111	; wide base
    968  f47c		       00 42	   CONE3      =	%01000010
    969  f47c		       00 7e	   CONE4      =	%01111110
    970  f47c		       00 24	   CONE5      =	%00100100
    971  f47c		       00 18	   CONE6      =	%00011000
    972  f47c		       00 18	   CONE7      =	%00011000	; point (top)
    973  f47c		       00 00	   SKULL0     =	%00000000
    974  f47c		       00 00	   SKULL1     =	%00000000
    975  f47c		       00 3c	   SKULL2     =	%00111100
    976  f47c		       00 7e	   SKULL3     =	%01111110
    977  f47c		       00 e7	   SKULL4     =	%11100111	; eyes
    978  f47c		       00 bd	   SKULL5     =	%10111101
    979  f47c		       00 7e	   SKULL6     =	%01111110
    980  f47c		       00 3c	   SKULL7     =	%00111100	; top
    981  f47c
    982  f47c					      MAC	cone_rows
    983  f47c					      .byte	(CONE0<<{1})&$FF,(CONE1<<{1})&$FF,(CONE2<<{1})&$FF,(CONE3<<{1})&$FF
    984  f47c					      .byte	(CONE4<<{1})&$FF,(CONE5<<{1})&$FF,(CONE6<<{1})&$FF,(CONE7<<{1})&$FF
    985  f47c					      ENDM		; {1} = left-shift amount (asl); 0 = base art
    986  f47c					      MAC	skull_rows
    987  f47c					      .byte	(SKULL0<<{1})&$FF,(SKULL1<<{1})&$FF,(SKULL2<<{1})&$FF,(SKULL3<<{1})&$FF
    988  f47c					      .byte	(SKULL4<<{1})&$FF,(SKULL5<<{1})&$FF,(SKULL6<<{1})&$FF,(SKULL7<<{1})&$FF
    989  f47c					      ENDM
    990  f47c							; (ZeroSprite / ConeSprite / SkullSprite base art + the slide tables all live
    991  f47c							;  together in page f5 -- see the block after JumpTabM0.)
