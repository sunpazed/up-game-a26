    871  f3f6		       85 c6		      sta	scoreBCD+1
    872  f3f8		       a5 c7		      lda	scoreBCD+2
    873  f3fa		       69 00		      adc	#0
    874  f3fc		       85 c7		      sta	scoreBCD+2
    875  f3fe		       d8		      cld
