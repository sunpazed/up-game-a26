   1324  f8da							;-------------------------------------------------------------
   1325  f8da							; UpdateSound - advance the one-shot SFX on channel 0 (called every frame in
   1326  f8da							;   all game states, so the death sound keeps playing through the freeze).
   1327  f8da							;   sfxTimer counts down; AUDC0/AUDF0/AUDV0 are derived from the id + timer.
   1328  f8da							;-------------------------------------------------------------
   1329  f8da				   UpdateSound
   1330  f8da		       a5 c3		      lda	sfxTimer
   1331  f8dc		       d0 01		      bne	.usPlay
   1332  f8de		       60		      rts		; idle (already silent)
   1333  f8df				   .usPlay
   1334  f8df		       c6 c3		      dec	sfxTimer
   1335  f8e1		       f0 11		      beq	.usSilence	; last frame elapsed -> turn the channel off
   1336  f8e3		       a5 c2		      lda	sfxId
   1337  f8e5		       c9 01		      cmp	#SFX_JUMP
   1338  f8e7		       f0 10		      beq	.usJump
   1339  f8e9		       c9 02		      cmp	#SFX_DROP
   1340  f8eb		       f0 1c		      beq	.usDrop
   1341  f8ed		       c9 03		      cmp	#SFX_CONE
   1342  f8ef		       f0 28		      beq	.usCone
   1343  f8f1		       4c 31 f9 	      jmp	.usDeath
   1344  f8f4				   .usSilence
   1345  f8f4		       a9 00		      lda	#0
   1346  f8f6		       85 19		      sta	AUDV0
   1347  f8f8		       60		      rts
   1348  f8f9
   1349  f8f9				   .usJump		; pure tone, pitch RISES (AUDF falls as timer falls)
   1350  f8f9		       a9 04		      lda	#SFX_TONE
   1351  f8fb		       85 15		      sta	AUDC0
   1352  f8fd		       a5 c3		      lda	sfxTimer
   1353  f8ff		       18		      clc
   1354  f900		       69 03		      adc	#3
   1355  f902		       85 17		      sta	AUDF0
   1356  f904		       a9 0a		      lda	#SFX_VOL
   1357  f906		       85 19		      sta	AUDV0
   1358  f908		       60		      rts
   1359  f909
   1360  f909				   .usDrop		; pure tone, pitch FALLS (AUDF rises as timer falls)
   1361  f909		       a9 04		      lda	#SFX_TONE
   1362  f90b		       85 15		      sta	AUDC0
   1363  f90d		       a9 0c		      lda	#DROP_DUR
   1364  f90f		       38		      sec
   1365  f910		       e5 c3		      sbc	sfxTimer
   1366  f912		       85 17		      sta	AUDF0
   1367  f914		       a9 0a		      lda	#SFX_VOL
   1368  f916		       85 19		      sta	AUDV0
