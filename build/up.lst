    272  f090							;-------------------------------------------------------------
    273  f090				   NextFrame
    274  f090		       a9 02		      lda	#2
    275  f092		       85 01		      sta	VBLANK
      0  f094					      VERTICAL_SYNC		; 3 vsync lines (leaves A=0)
      1  f094		       a9 0e		      lda	#%1110
      2  f096		       85 02	   .VSLP1     sta	WSYNC
      3  f098		       85 00		      sta	VSYNC
      4  f09a		       4a		      lsr
      5  f09b		       d0 f9		      bne	.VSLP1
    277  f09d		       85 2c		      sta	CXCLR	; clear collision latches for this frame
    278  f09f
    279  f09f							; --- position the score sprites (P0+P1, 3 copies each = 6 digits) ---
    280  f09f							; (uses 2 of the 36 VBLANK scanlines; the rest are the WSYNC loop below)
    281  f09f		       a9 03		      lda	#THREE_COPIES
    282  f0a1		       85 04		      sta	NUSIZ0
    283  f0a3		       85 05		      sta	NUSIZ1
    284  f0a5		       a9 00		      lda	#SCORE_COL
    285  f0a7		       85 06		      sta	COLUP0
    286  f0a9		       85 07		      sta	COLUP1
    287  f0ab		       85 02		      sta	WSYNC	; vblank line 1
      0  f0ad					      SLEEP	SCORE_SLEEP
      1  f0ad				   .CYCLES    SET	SCORE_SLEEP
      2  f0ad
      3  f0ad				  -	      IF	.CYCLES < 2
      4  f0ad				  -	      ECHO	"MACRO ERROR: 'SLEEP': Duration must be > 1"
      5  f0ad				  -	      ERR
      6  f0ad					      ENDIF
      7  f0ad
      8  f0ad				  -	      IF	.CYCLES & 1
      9  f0ad				  -	      IFNCONST	NO_ILLEGAL_OPCODES
     10  f0ad				  -	      nop	0
     11  f0ad				  -	      ELSE
     12  f0ad				  -	      bit	VSYNC
     13  f0ad				  -	      ENDIF
     14  f0ad				  -.CYCLES    SET	.CYCLES - 3
     15  f0ad					      ENDIF
     16  f0ad
     17  f0ad					      REPEAT	.CYCLES / 2
     18  f0ad		       ea		      nop
     17  f0ad					      REPEND
     18  f0ae		       ea		      nop
     17  f0ae					      REPEND
     18  f0af		       ea		      nop
     17  f0af					      REPEND
     18  f0b0		       ea		      nop
     17  f0b0					      REPEND
     18  f0b1		       ea		      nop
     17  f0b1					      REPEND
     18  f0b2		       ea		      nop
     17  f0b2					      REPEND
     18  f0b3		       ea		      nop
