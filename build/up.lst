    713  f354							; CheckRestart - during game over, a fresh fire press restarts.
    714  f354							;-------------------------------------------------------------
    715  f354				   CheckRestart
    716  f354		       a2 00		      ldx	#0
    717  f356		       a5 0c		      lda	INPT4
