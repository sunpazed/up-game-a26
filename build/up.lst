    167  f00b
    168  f00b							; --- one-time setup (survives a soft restart) ---
    169  f00b							; Solid, full-width playfield (held for the whole program)
    170  f00b		       a9 f0		      lda	#$F0
    171  f00d		       85 0d		      sta	PF0
    172  f00f		       a9 ff		      lda	#$FF
    173  f011		       85 0e		      sta	PF1
    174  f013		       85 0f		      sta	PF2
    175  f015		       a9 00		      lda	#0
    176  f017		       85 0a		      sta	CTRLPF	; players/missiles draw over the playfield
    177  f019
    178  f019							; Missile 0 is GAP_WIDTH wide (player stays normal width)
    179  f019		       a9 30		      lda	#$30
    180  f01b		       85 04		      sta	NUSIZ0
    181  f01d
    182  f01d							; Default every motion register to $80, the cycle-74 HMOVE "no motion"
    183  f01d							; value: the per-band cycle-74 HMOVEs re-apply ALL HMxx, and $00 there
    184  f01d							; is NOT zero motion (it would walk the object); $80 (NO_MO_74) holds
    185  f01d							; non-targeted objects still. The player P0 is (re)placed each frame in
    186  f01d							; the HUD transition; gaps/entities are placed per band.
    187  f01d		       85 2b		      sta	HMCLR
    188  f01f		       a9 80		      lda	#$80
    189  f021		       85 20		      sta	HMP0
    190  f023		       85 22		      sta	HMM0
    191  f025		       85 21		      sta	HMP1
    192  f027
    193  f027		       a9 01		      lda	#1
    194  f029		       85 c0		      sta	rng	; PRNG seed (set once; advances across games)
    195  f02b
    196  f02b		       a9 00		      lda	#0
    197  f02d		       85 19		      sta	AUDV0	; silence both audio channels at boot
    198  f02f		       85 1a		      sta	AUDV1
    199  f031
    200  f031							;-------------------------------------------------------------
    201  f031							; NewGame - (re)start a round. Reached from Reset and from a game-over
    202  f031							; restart. Resets all gameplay state but NOT hiScore (or rng).
    203  f031							;-------------------------------------------------------------
    204  f031				   NewGame
    205  f031		       a9 0e		      lda	#COL_BG
    206  f033		       85 09		      sta	COLUBK	; clear any game-over red tint
    207  f035
    208  f035		       a9 05		      lda	#5
    209  f037		       85 80		      sta	playerFloor	; player starts on the bottom tier
    210  f039		       a9 00		      lda	#0
    211  f03b		       85 82		      sta	btnPrev
    212  f03d		       85 c4		      sta	gameState
    213  f03f		       85 ca		      sta	goCnt
    214  f041		       85 c3		      sta	sfxTimer	; stop any leftover sound (e.g. the death sting)
    215  f043		       85 c5		      sta	scoreBCD+0
    216  f045		       85 c6		      sta	scoreBCD+1
    217  f047		       85 c7		      sta	scoreBCD+2
    218  f049		       85 b0		      sta	scrollFrac
    219  f04b		       85 cb		      sta	animFrame	; start on run-cycle frame 0
    220  f04d		       a9 16		      lda	#ANIM_BASE
    221  f04f		       85 cc		      sta	animTimer
    222  f051		       a9 20		      lda	#SPEED_BASE
    223  f053		       85 af		      sta	scrollSpeed	; start each game at base speed (1 px/frame)
    224  f055
    225  f055							; Staggered initial gap positions (floor 5 has no gap)
    226  f055		       a9 8c		      lda	#140
    227  f057		       85 8b		      sta	gapX+0
    228  f059		       a9 6e		      lda	#110
    229  f05b		       85 8c		      sta	gapX+1
    230  f05d		       a9 50		      lda	#80
    231  f05f		       85 8d		      sta	gapX+2
    232  f061		       a9 32		      lda	#50
    233  f063		       85 8e		      sta	gapX+3
    234  f065		       a9 82		      lda	#130
    235  f067		       85 8f		      sta	gapX+4
    236  f069		       a9 00		      lda	#0
    237  f06b		       85 90		      sta	gapX+5
    238  f06d
    239  f06d							; Reseed the PRNG from the free-running frame counter (mixed with whatever
    240  f06d							; state carried over), so each restart differs -- the human-variable delay
    241  f06d							; before pressing fire makes frameCnt effectively random. Keep it non-zero
    242  f06d							; (an all-zero LFSR is a dead state).
    243  f06d		       a5 c0		      lda	rng
    244  f06f		       45 c1		      eor	frameCnt
    245  f071		       d0 02		      bne	.seedOk
    246  f073		       a9 01		      lda	#1
    247  f075				   .seedOk
    248  f075		       85 c0		      sta	rng
    249  f077
    250  f077							; Start with EMPTY platforms: every entity begins hidden and slides in from
    251  f077							; the right edge on a staggered delay (via the normal respawn path, which
    252  f077							; rolls a random type and clears gaps). This guarantees reaction time on any
    253  f077							; floor the player jumps to -- nothing is ever sitting in the jump path at
    254  f077							; the fixed player x. entX is set when each one spawns; entDrawLo = blank.
    255  f077		       a2 05		      ldx	#5
    256  f079				   .ngEnt
    257  f079		       a9 00		      lda	#0
    258  f07b		       95 9d		      sta	entType,x	; hidden -> .entWaiting spawns it (slide-in)
    259  f07d		       95 cd		      sta	entSlide,x
    260  f07f		       95 d9		      sta	entRefp,x
    261  f081		       a9 30		      lda	#<ZeroSprite
    262  f083		       95 d3		      sta	entDrawLo,x
    263  f085		       bd 89 f4 	      lda	InitDelayTab,x	; staggered first-spawn delay per floor
    264  f088		       95 a9		      sta	entDelay,x
    265  f08a		       ca		      dex
    266  f08b		       10 ec		      bpl	.ngEnt
    267  f08d
    268  f08d		       20 5a f8 	      jsr	GetDigitPtrs	; seed digit pointers for the first HUD
    269  f090
