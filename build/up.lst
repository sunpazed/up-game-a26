    630  f2d6							; --- entities: scroll, hide for a random delay, re-enter ---
    631  f2d6		       a2 05		      ldx	#5
    632  f2d8				   .entLoop
    633  f2d8		       b5 9d		      lda	entType,x
    634  f2da		       f0 0e		      beq	.entWaiting	; type 0 = hidden, waiting to respawn
    635  f2dc		       d6 a3		      dec	entX,x
