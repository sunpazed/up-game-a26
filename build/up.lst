    647  f2d5							;-------------------------------------------------------------
    648  f2d5							; AnimatePlayer - tick the run-cycle frame. Swaps frame every animTimer
    649  f2d5							;   frames; the interval shortens with scroll speed so the player's legs
    650  f2d5							;   move faster as the world speeds up.
    651  f2d5							;   interval = ANIM_BASE - (scrollSpeed >> 3)
    652  f2d5							;-------------------------------------------------------------
