    219  f043		       85 c5		      sta	scoreBCD+0
    220  f045		       85 c6		      sta	scoreBCD+1
    221  f047		       85 c7		      sta	scoreBCD+2
    222  f049		       85 b0		      sta	scrollFrac
    223  f04b		       85 cb		      sta	animFrame	; start on run-cycle frame 0
    224  f04d		       a9 16		      lda	#ANIM_BASE
    225  f04f		       85 cc		      sta	animTimer
    226  f051		       a9 20		      lda	#SPEED_BASE
    227  f053		       85 af		      sta	scrollSpeed	; start each game at base speed (1 px/frame)
    228  f055
    229  f055							; (gap layout is randomised below, after the PRNG is reseeded)
    230  f055
    231  f055							; Reseed the PRNG from the free-running frame counter (mixed with whatever
    232  f055							; state carried over), so each restart differs -- the human-variable delay
    233  f055							; before pressing fire makes frameCnt effectively random. Keep it non-zero
    234  f055							; (an all-zero LFSR is a dead state).
    235  f055		       a5 c0		      lda	rng
    236  f057		       45 c1		      eor	frameCnt
    237  f059		       d0 02		      bne	.seedOk
    238  f05b		       a9 01		      lda	#1
    239  f05d				   .seedOk
    240  f05d		       85 c0		      sta	rng
    241  f05f
    242  f05f							; Randomise the gap (slot) layout per game. Each floor gets a fully random x;
    243  f05f							; re-roll any that lands within GAP_MIN_SEP of the floor below so holes never
    244  f05f							; stack (which would drop the player straight through) -- but the result is
    245  f05f							; non-monotonic (no rigid diagonal). Candidates stay in 16..143 (away from the
    246  f05f							; 0/159 wrap zone, so the same separation holds as they scroll). Floor 5: none.
    247  f05f		       a2 04		      ldx	#4
    248  f061				   .ngGapFloor
    249  f061		       a0 08		      ldy	#8	; re-roll attempt cap (collisions are rare)
    250  f063				   .ngGapRoll
    251  f063		       20 c9 f2 	      jsr	Rng	; (Rng preserves X and Y)
    252  f066		       29 7f		      and	#$7F
    253  f068		       18		      clc
    254  f069		       69 10		      adc	#16	; candidate 16..143
    255  f06b		       85 85		      sta	tempOne
    256  f06d		       e0 04		      cpx	#4
    257  f06f		       f0 11		      beq	.ngGapOk	; first floor placed: nothing below to clash with
    258  f071		       38		      sec
    259  f072		       f5 8c		      sbc	gapX+1,x	; A = candidate - gap on the floor below
    260  f074		       b0 05		      bcs	.ngGapAbs
    261  f076		       49 ff		      eor	#$FF
    262  f078		       18		      clc
    263  f079		       69 01		      adc	#1	; A = |difference|
    264  f07b				   .ngGapAbs
    265  f07b		       c9 18		      cmp	#GAP_MIN_SEP
    266  f07d		       b0 03		      bcs	.ngGapOk	; far enough from the floor below -> accept
    267  f07f		       88		      dey
    268  f080		       d0 e1		      bne	.ngGapRoll	; too close -> re-roll (capped)
    269  f082				   .ngGapOk
    270  f082		       a5 85		      lda	tempOne
    271  f084		       95 8b		      sta	gapX,x
    272  f086		       ca		      dex
    273  f087		       10 d8		      bpl	.ngGapFloor
    274  f089		       a9 00		      lda	#0
    275  f08b		       85 90		      sta	gapX+5
    276  f08d
    277  f08d							; Start with EMPTY platforms: every entity begins hidden and slides in from
    278  f08d							; the right edge (via the normal respawn path, which rolls a random type and
    279  f08d							; clears gaps). Each gets a RANDOM first-spawn delay so they don't all enter
    280  f08d							; evenly spaced (which read as a rigid diagonal). entX is set on spawn.
    281  f08d		       a2 05		      ldx	#5
