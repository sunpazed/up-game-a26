    719  f35a		       a2 01		      ldx	#1
    720  f35c		       a5 82		      lda	btnPrev
    721  f35e		       d0 03		      bne	.crStore	; held since last frame -> no edge
    722  f360		       4c 2b f0 	      jmp	NewGame	; fresh press -> restart (keeps hiScore)
    723  f363				   .crStore
    724  f363		       86 82		      stx	btnPrev
