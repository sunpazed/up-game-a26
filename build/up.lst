    728  f366							; CalcQuickPos - A = x (0..159) -> A = quickPos
    729  f366							;   quickPos = (HMOVE fine nibble << 4) | delay count (low nibble).
    730  f366							;   Fast divide-by-15 + tables, from examples/hmove74.asm. Uses Y, tempOne.
