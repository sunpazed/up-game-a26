     92 U0080		       00	   playerFloor ds	1	; 0 = top tier .. 5 = bottom tier
     93 U0081		       00	   playerBandCount ds	1	; bandCount value at which to draw the player
     94 U0082		       00	   btnPrev    ds	1	; fire button state last frame (edge detect)
     95 U0083		       00	   bandCount  ds	1	; bands remaining in the visible kernel
     96 U0084		       00	   curFloor   ds	1	; floor index of the band being drawn
     97 U0085		       00	   tempOne    ds	1	; scratch for the fast divide in CalcQuickPos
     98 U0086		       00	   tempFloor  ds	1	; scratch floor index across CalcQuickPos
     99 U0087		       00 00	   sprPtr     ds	2	; pointer to current band's sprite data
    100 U0089		       00 00	   posJmp     ds	2	; indirect pointer into the missile strobe table
    101 U008b		       00 00 00 00*gapX       ds	6	; per-floor gap x position (floor 5 unused/no gap)
    102 U0091		       00 00 00 00*gapQuick   ds	6	; per-floor precomputed quickPos (HMM0 fine | delay count)
    103 U0097		       00 00 00 00*posJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    104 U009d		       00 00 00 00*entType    ds	6	; per-floor entity: 0 none/hidden, 1 cone, 2 skull
    105 U00a3		       00 00 00 00*entX       ds	6	; per-floor entity x position
    106 U00a9		       00 00 00 00*entDelay   ds	6	; per-floor frames left to wait off-screen before respawn
    107 U00af		       00	   scrollSpeed ds	1	; fractional scroll speed (ramps with score)
    108 U00b0		       00	   scrollFrac ds	1	; fixed-point fractional accumulator
    109 U00b1		       00	   scrollStep ds	1	; whole pixels to scroll this frame
    110 U00b2		       00 00 00 00*entQuick   ds	6	; per-floor precomputed quickPos for the entity (GRP1)
    111 U00b8		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    112 U00be		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    113 U00c0		       00	   rng	      ds	1	; PRNG state (LFSR)
    114 U00c1		       00	   gameState  ds	1	; 0 = playing, 1 = game over
    115 U00c2		       00 00 00    scoreBCD   ds	3	; BCD score (low 4 digits shown)
    116 U00c5		       00 00	   hiScore    ds	2	; 4-digit BCD high score (persists across games)
    117 U00c7		       00	   goCnt      ds	1	; game-over text cycle: 0-119 GAMEOVER, 120-239 HInnnn
    118 U00c8		       00 00 00 00*Digit0     ds	12	; 6 font pointers (Digit0..Digit5) for the score kernel
    119 U00d4		       00	   loopCnt    ds	1	; scanline counter inside DrawDigits
