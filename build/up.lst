   1195  f798							; DrawDigits - render the 48x8 score from Digit0..Digit5 pointers.
   1196  f798							; Page-aligned so BigLoop's branch stays in-page (exact 76-cycle rows).
   1197  f798							; After examples/6-digit-score.asm (Temp -> tempOne, LoopCount -> loopCnt).
   1198  f798							;-------------------------------------------------------------
   1199  f800		       00 00 00 00*	      align	$100
   1200  f800				   DrawDigits
   1201  f800		       a9 07		      lda	#7
   1202  f802		       85 eb		      sta	loopCnt
   1203  f804		       85 02		      sta	WSYNC
      0  f806					      SLEEP	60
      1  f806				   .CYCLES    SET	60
      2  f806
      3  f806				  -	      IF	.CYCLES < 2
      4  f806				  -	      ECHO	"MACRO ERROR: 'SLEEP': Duration must be > 1"
      5  f806				  -	      ERR
      6  f806					      ENDIF
      7  f806
      8  f806				  -	      IF	.CYCLES & 1
      9  f806				  -	      IFNCONST	NO_ILLEGAL_OPCODES
     10  f806				  -	      nop	0
     11  f806				  -	      ELSE
     12  f806				  -	      bit	VSYNC
     13  f806				  -	      ENDIF
     14  f806				  -.CYCLES    SET	.CYCLES - 3
     15  f806					      ENDIF
     16  f806
     17  f806					      REPEAT	.CYCLES / 2
     18  f806		       ea		      nop
     17  f806					      REPEND
     18  f807		       ea		      nop
     17  f807					      REPEND
     18  f808		       ea		      nop
     17  f808					      REPEND
     18  f809		       ea		      nop
     17  f809					      REPEND
     18  f80a		       ea		      nop
     17  f80a					      REPEND
     18  f80b		       ea		      nop
     17  f80b					      REPEND
     18  f80c		       ea		      nop
     17  f80c					      REPEND
     18  f80d		       ea		      nop
