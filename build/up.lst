    688  f2fa		       a5 af		      lda	scrollSpeed
    689  f2fc		       4a		      lsr
    690  f2fd		       4a		      lsr
    691  f2fe		       4a		      lsr		; scrollSpeed >> 3
    692  f2ff		       85 cc		      sta	animTimer	; (temp)
