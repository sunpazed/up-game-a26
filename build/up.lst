    649  f2fe		       c9 02		      cmp	#ENT_SKULL
    650  f300		       f0 28		      beq	.ccSkull
    651  f302							; cone collected: +1 (BCD). GetDigitPtrs shows scoreBCD+2 as the
    652  f302							; leftmost (most-significant) digits, so the +1 must land on the
    653  f302							; least-significant byte scoreBCD+0 and carry up toward +2.
    654  f302		       f8		      sed
    655  f303		       a5 c2		      lda	scoreBCD+0
    656  f305		       18		      clc
    657  f306		       69 01		      adc	#1
    658  f308		       85 c2		      sta	scoreBCD+0
    659  f30a		       a5 c3		      lda	scoreBCD+1
    660  f30c		       69 00		      adc	#0
    661  f30e		       85 c3		      sta	scoreBCD+1
    662  f310		       a5 c4		      lda	scoreBCD+2
    663  f312		       69 00		      adc	#0
    664  f314		       85 c4		      sta	scoreBCD+2
    665  f316		       d8		      cld
    666  f317		       a9 00		      lda	#0
    667  f319		       95 9d		      sta	entType,x	; cone consumed
    668  f31b		       20 e9 f2 	      jsr	SetRespawnDelay	; wait before a new entity enters this floor
    669  f31e							; ramp the scroll speed (sub-pixel speed-up with score)
    670  f31e		       a5 af		      lda	scrollSpeed
    671  f320		       c9 80		      cmp	#SPEED_MAX
    672  f322		       b0 24		      bcs	.ccDone	; already at max
    673  f324		       18		      clc
    674  f325		       69 01		      adc	#SPEED_INC
    675  f327		       85 af		      sta	scrollSpeed
    676  f329		       60		      rts
    677  f32a				   .ccSkull
    678  f32a		       a9 01		      lda	#1
    679  f32c		       85 c1		      sta	gameState
