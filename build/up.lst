    822  f3d2		       0a		      asl
    823  f3d3		       0a		      asl
    824  f3d4		       0a		      asl		; * 8
    825  f3d5		       95 ca		      sta	Digit0,x
    826  f3d7		       e8		      inx
    827  f3d8		       e8		      inx
    828  f3d9		       88		      dey
    829  f3da		       10 e7		      bpl	.gdpLoop
    830  f3dc		       4c 26 f4 	      jmp	.setHi
