    181  f019
    182  f019							; Missile 0 is GAP_WIDTH wide (player stays normal width)
    183  f019		       a9 30		      lda	#$30
    184  f01b		       85 04		      sta	NUSIZ0
    185  f01d
    186  f01d							; Default every motion register to $80, the cycle-74 HMOVE "no motion"
    187  f01d							; value: the per-band cycle-74 HMOVEs re-apply ALL HMxx, and $00 there
    188  f01d							; is NOT zero motion (it would walk the object); $80 (NO_MO_74) holds
    189  f01d							; non-targeted objects still. The player P0 is (re)placed each frame in
    190  f01d							; the HUD transition; gaps/entities are placed per band.
    191  f01d		       85 2b		      sta	HMCLR
    192  f01f		       a9 80		      lda	#$80
    193  f021		       85 20		      sta	HMP0
    194  f023		       85 22		      sta	HMM0
    195  f025		       85 21		      sta	HMP1
    196  f027
