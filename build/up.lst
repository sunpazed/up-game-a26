    733  f366		       85 85		      sta	tempOne
    734  f368		       4a		      lsr
    735  f369		       69 04		      adc	#4
    736  f36b		       4a		      lsr
    737  f36c		       4a		      lsr
    738  f36d		       4a		      lsr
    739  f36e		       65 85		      adc	tempOne
    740  f370		       6a		      ror
    741  f371		       4a		      lsr
    742  f372		       4a		      lsr
    743  f373		       4a		      lsr
    744  f374		       a8		      tay		; Y = x / 15
    745  f375		       b9 0a f4 	      lda	MultTab,y
    746  f378		       38		      sec
    747  f379		       e5 85		      sbc	tempOne
    748  f37b		       0a		      asl
    749  f37c		       0a		      asl
    750  f37d		       0a		      asl
    751  f37e		       0a		      asl
    752  f37f		       18		      clc
