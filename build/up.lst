    693  f330							;-------------------------------------------------------------
    694  f330							; CheckCollision - player vs the entity on the player's floor.
    695  f330							;   cone  -> +1 to the BCD score, entity consumed.
    696  f330							;   skull -> game over (freeze + red background).
    697  f330							;-------------------------------------------------------------
    698  f330				   CheckCollision
    699  f330		       a5 07		      lda	CXPPMM
    700  f332		       10 50		      bpl	.ccDone	; bit7 (P0-P1) clear -> player didn't touch an entity
    701  f334							; player's GRP0 only draws on its own floor, so a P0-P1 hit is the
    702  f334							; entity on playerFloor. Act on its type.
    703  f334		       a6 80		      ldx	playerFloor
    704  f336		       b5 9d		      lda	entType,x
    705  f338		       f0 4a		      beq	.ccDone	; guard: no entity here
    706  f33a		       c9 02		      cmp	#ENT_SKULL
    707  f33c		       f0 28		      beq	.ccSkull
    708  f33e							; cone collected: +1 (BCD). GetDigitPtrs shows scoreBCD+2 as the
    709  f33e							; leftmost (most-significant) digits, so the +1 must land on the
    710  f33e							; least-significant byte scoreBCD+0 and carry up toward +2.
    711  f33e		       f8		      sed
    712  f33f		       a5 c2		      lda	scoreBCD+0
    713  f341		       18		      clc
    714  f342		       69 01		      adc	#1
    715  f344		       85 c2		      sta	scoreBCD+0
    716  f346		       a5 c3		      lda	scoreBCD+1
    717  f348		       69 00		      adc	#0
    718  f34a		       85 c3		      sta	scoreBCD+1
    719  f34c		       a5 c4		      lda	scoreBCD+2
    720  f34e		       69 00		      adc	#0
    721  f350		       85 c4		      sta	scoreBCD+2
    722  f352		       d8		      cld
    723  f353		       a9 00		      lda	#0
    724  f355		       95 9d		      sta	entType,x	; cone consumed
    725  f357		       20 25 f3 	      jsr	SetRespawnDelay	; wait before a new entity enters this floor
    726  f35a							; ramp the scroll speed (sub-pixel speed-up with score)
    727  f35a		       a5 af		      lda	scrollSpeed
    728  f35c		       c9 80		      cmp	#SPEED_MAX
    729  f35e		       b0 24		      bcs	.ccDone	; already at max
    730  f360		       18		      clc
    731  f361		       69 01		      adc	#SPEED_INC
    732  f363		       85 af		      sta	scrollSpeed
    733  f365		       60		      rts
    734  f366				   .ccSkull
