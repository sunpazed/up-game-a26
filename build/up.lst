    840  f3d7		       a5 c6		      lda	scoreBCD+1
    841  f3d9		       69 00		      adc	#0
    842  f3db		       85 c6		      sta	scoreBCD+1
    843  f3dd		       a5 c7		      lda	scoreBCD+2
    844  f3df		       69 00		      adc	#0
    845  f3e1		       85 c7		      sta	scoreBCD+2
