    879  f429							;-------------------------------------------------------------
    880  f429							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
    881  f429							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
    882  f429							;   (After examples/6-digit-score.asm.)
    883  f429							;-------------------------------------------------------------
    884  f429				   GetDigitPtrs
    885  f429		       a5 c1		      lda	gameState
    886  f42b		       d0 26		      bne	.goText
    887  f42d							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
    888  f42d		       a9 50		      lda	#<BlankGlyph
    889  f42f		       85 dc		      sta	Digit0+0
    890  f431		       85 de		      sta	Digit0+2
    891  f433		       a2 04		      ldx	#4
    892  f435		       a0 01		      ldy	#1
    893  f437				   .gdpLoop
    894  f437		       b9 c2 00 	      lda	scoreBCD,y
    895  f43a		       29 f0		      and	#$f0	; high nibble * 16
    896  f43c		       4a		      lsr		; -> * 8
    897  f43d		       95 dc		      sta	Digit0,x
    898  f43f		       e8		      inx
    899  f440		       e8		      inx
    900  f441		       b9 c2 00 	      lda	scoreBCD,y
    901  f444		       29 0f		      and	#$0f	; low nibble
    902  f446		       0a		      asl
    903  f447		       0a		      asl
    904  f448		       0a		      asl		; * 8
    905  f449		       95 dc		      sta	Digit0,x
    906  f44b		       e8		      inx
    907  f44c		       e8		      inx
    908  f44d		       88		      dey
    909  f44e		       10 e7		      bpl	.gdpLoop
    910  f450		       4c 9a f4 	      jmp	.setHi
    911  f453				   .goText
    912  f453							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
    913  f453		       a5 c7		      lda	goCnt
    914  f455		       c9 78		      cmp	#120
    915  f457		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
    916  f459							; "GAMEOVER" packed across the 6 glyph slots
    917  f459		       a9 58		      lda	#<GameOverGlyphs
    918  f45b		       85 dc		      sta	Digit0+0
    919  f45d		       18		      clc
    920  f45e		       69 08		      adc	#8
    921  f460		       85 de		      sta	Digit0+2
    922  f462		       69 08		      adc	#8
    923  f464		       85 e0		      sta	Digit0+4
    924  f466		       69 08		      adc	#8
    925  f468		       85 e2		      sta	Digit0+6
    926  f46a		       69 08		      adc	#8
    927  f46c		       85 e4		      sta	Digit0+8
    928  f46e		       69 08		      adc	#8
    929  f470		       85 e6		      sta	Digit0+10
    930  f472		       4c 9a f4 	      jmp	.setHi
    931  f475				   .goHi
    932  f475							; "HI" + the 4-digit high score
    933  f475		       a9 88		      lda	#<LetterH
    934  f477		       85 dc		      sta	Digit0+0
    935  f479		       a9 90		      lda	#<LetterI
    936  f47b		       85 de		      sta	Digit0+2
    937  f47d		       a2 04		      ldx	#4
    938  f47f		       a0 01		      ldy	#1
    939  f481				   .goHiLoop
    940  f481		       b9 c5 00 	      lda	hiScore,y
    941  f484		       29 f0		      and	#$f0
    942  f486		       4a		      lsr
    943  f487		       95 dc		      sta	Digit0,x
    944  f489		       e8		      inx
    945  f48a		       e8		      inx
    946  f48b		       b9 c5 00 	      lda	hiScore,y
    947  f48e		       29 0f		      and	#$0f
    948  f490		       0a		      asl
    949  f491		       0a		      asl
    950  f492		       0a		      asl
    951  f493		       95 dc		      sta	Digit0,x
    952  f495		       e8		      inx
    953  f496		       e8		      inx
    954  f497		       88		      dey
    955  f498		       10 e7		      bpl	.goHiLoop
    956  f49a				   .setHi
    957  f49a							; every glyph lives in the FontTable page, so all hi bytes are the same
    958  f49a		       a9 f7		      lda	#>FontTable
    959  f49c		       85 dd		      sta	Digit0+1
    960  f49e		       85 df		      sta	Digit0+3
    961  f4a0		       85 e1		      sta	Digit0+5
    962  f4a2		       85 e3		      sta	Digit0+7
    963  f4a4		       85 e5		      sta	Digit0+9
    964  f4a6		       85 e7		      sta	Digit0+11
