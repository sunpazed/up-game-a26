     27  10000 ????		00 05	    LANE_LAST  equ	5
     28  10000 ????
     29  10000 ????		00 28	    PLAYER_X_RESET equ	40
     30  10000 ????		00 05	    PLAYER_START_LANE equ	5
     31  10000 ????		00 24	    PLAYER_GAP_MIN equ	36
     32  10000 ????		00 2c	    PLAYER_GAP_MAX equ	44
     33  10000 ????
