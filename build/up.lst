   1235  f85a							;-------------------------------------------------------------
   1236  f85a							; GetDigitPtrs - build the 6 font pointers (Digit0..Digit5) from the
   1237  f85a							;   3-byte BCD score. Each nibble * 8 = offset into FontTable.
   1238  f85a							;   (After examples/6-digit-score.asm.) Lives here in the trailing gap to
   1239  f85a							;   keep the cramped $f000-$f500 code region under the PosTblM0 org.
   1240  f85a							;-------------------------------------------------------------
   1241  f85a				   GetDigitPtrs
   1242  f85a		       a5 c4		      lda	gameState
   1243  f85c		       d0 26		      bne	.goText
   1244  f85e							; --- playing: score "__nnnn" (blank leftmost two, low 4 BCD digits) ---
   1245  f85e		       a9 50		      lda	#<BlankGlyph
   1246  f860		       85 df		      sta	Digit0+0
   1247  f862		       85 e1		      sta	Digit0+2
   1248  f864		       a2 04		      ldx	#4
   1249  f866		       a0 01		      ldy	#1
   1250  f868				   .gdpLoop
   1251  f868		       b9 c5 00 	      lda	scoreBCD,y
   1252  f86b		       29 f0		      and	#$f0	; high nibble * 16
   1253  f86d		       4a		      lsr		; -> * 8
   1254  f86e		       95 df		      sta	Digit0,x
   1255  f870		       e8		      inx
   1256  f871		       e8		      inx
   1257  f872		       b9 c5 00 	      lda	scoreBCD,y
   1258  f875		       29 0f		      and	#$0f	; low nibble
   1259  f877		       0a		      asl
   1260  f878		       0a		      asl
   1261  f879		       0a		      asl		; * 8
   1262  f87a		       95 df		      sta	Digit0,x
   1263  f87c		       e8		      inx
   1264  f87d		       e8		      inx
   1265  f87e		       88		      dey
   1266  f87f		       10 e7		      bpl	.gdpLoop
   1267  f881		       4c cb f8 	      jmp	.setHi
   1268  f884				   .goText
   1269  f884							; --- game over: alternate "GAMEOVER" and "HInnnn" every 120 frames ---
   1270  f884		       a5 ca		      lda	goCnt
   1271  f886		       c9 78		      cmp	#120
   1272  f888		       b0 1c		      bcs	.goHi	; goCnt 120-239 -> HInnnn
   1273  f88a							; "GAMEOVER" packed across the 6 glyph slots
   1274  f88a		       a9 58		      lda	#<GameOverGlyphs
   1275  f88c		       85 df		      sta	Digit0+0
   1276  f88e		       18		      clc
   1277  f88f		       69 08		      adc	#8
   1278  f891		       85 e1		      sta	Digit0+2
   1279  f893		       69 08		      adc	#8
   1280  f895		       85 e3		      sta	Digit0+4
   1281  f897		       69 08		      adc	#8
   1282  f899		       85 e5		      sta	Digit0+6
   1283  f89b		       69 08		      adc	#8
   1284  f89d		       85 e7		      sta	Digit0+8
   1285  f89f		       69 08		      adc	#8
   1286  f8a1		       85 e9		      sta	Digit0+10
   1287  f8a3		       4c cb f8 	      jmp	.setHi
