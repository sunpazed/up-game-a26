    137 U00a3		       00 00 00 00*entX       ds	6	; per-floor entity x position
    138 U00a9		       00 00 00 00*entDelay   ds	6	; per-floor frames left to wait off-screen before respawn
    139 U00af		       00	   scrollSpeed ds	1	; fractional scroll speed (ramps with score)
    140 U00b0		       00	   scrollFrac ds	1	; fixed-point fractional accumulator
    141 U00b1		       00	   scrollStep ds	1	; whole pixels to scroll this frame
    142 U00b2		       00 00 00 00*entQuick   ds	6	; per-floor precomputed quickPos for the entity (GRP1)
    143 U00b8		       00 00 00 00*entJmpLo   ds	6	; per-floor precomputed strobe-table entry (low byte)
    144 U00be		       00 00	   entPtr     ds	2	; pointer to the current band's entity sprite
    145 U00c0		       00	   rng	      ds	1	; PRNG state (LFSR)
    146 U00c1		       00	   frameCnt   ds	1	; free-running frame counter (never reset; RNG reseed)
    147 U00c2		       00	   sfxId      ds	1	; sound effect currently playing (0 = none)
    148 U00c3		       00	   sfxTimer   ds	1	; frames left in the current sound effect
