    786  f3b4		       85 cc		      sta	Digit0+4
    787  f3b6		       69 08		      adc	#8
    788  f3b8		       85 ce		      sta	Digit0+6
    789  f3ba		       69 08		      adc	#8
    790  f3bc		       85 d0		      sta	Digit0+8
    791  f3be		       69 08		      adc	#8
    792  f3c0		       85 d2		      sta	Digit0+10
    793  f3c2		       4c ea f3 	      jmp	.setHi
    794  f3c5				   .goHi
    795  f3c5							; "HI" + the 4-digit high score
