    681  f330		       85 09		      sta	COLUBK	; red tint; NewGame restores COL_BG on restart
    682  f332							; high score = max(hiScore, score) over the low 4 digits
    683  f332		       a5 c3		      lda	scoreBCD+1
    684  f334		       c5 c6		      cmp	hiScore+1
    685  f336		       90 10		      bcc	.ccDone	; score's high pair < hiScore's
    686  f338		       d0 06		      bne	.ccNewHi	; score's high pair > hiScore's
    687  f33a		       a5 c2		      lda	scoreBCD+0
    688  f33c		       c5 c5		      cmp	hiScore+0
    689  f33e		       90 08		      bcc	.ccDone	; equal high pair, low pair lower
    690  f340				   .ccNewHi
