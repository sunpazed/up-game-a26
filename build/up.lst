    755  f379							;-------------------------------------------------------------
    756  f379							; SetRespawnDelay - arm entDelay[X] with a randomised off-screen wait.
    757  f379							;-------------------------------------------------------------
    758  f379				   SetRespawnDelay
    759  f379		       20 a3 f2 	      jsr	Rng
    760  f37c		       29 7f		      and	#ENT_DELAY_MASK
    761  f37e		       18		      clc
    762  f37f		       69 20		      adc	#ENT_DELAY_MIN
    763  f381		       95 a9		      sta	entDelay,x
    764  f383		       60		      rts
