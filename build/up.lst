    172  f00b							; --- one-time setup (survives a soft restart) ---
    173  f00b							; Solid, full-width playfield (held for the whole program)
    174  f00b		       a9 f0		      lda	#$F0
    175  f00d		       85 0d		      sta	PF0
    176  f00f		       a9 ff		      lda	#$FF
